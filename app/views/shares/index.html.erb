<% content_for :title, "Plex Shares" %>

<div class="mx-auto flex w-full max-w-[100rem] flex-col gap-6 px-4 py-6 sm:px-6 lg:px-8">
  <header class="flex flex-col gap-4 border-b border-zinc-800 pb-5 lg:flex-row lg:items-end lg:justify-between">
    <div>
      <p class="text-sm font-medium uppercase tracking-wide text-cyan-300">Plex library access</p>
      <h1 class="mt-2 text-3xl font-semibold tracking-normal text-white">Shared users</h1>
      <p class="mt-2 max-w-2xl text-sm leading-6 text-zinc-400">
        Local snapshot of who can access this Plex server and which libraries are shared with each account.
      </p>
    </div>

    <div class="flex flex-wrap gap-2">
      <%= link_to "Log", share_audit_logs_path, class: "inline-flex items-center justify-center rounded-md border border-zinc-700 px-4 py-2 text-sm font-semibold text-zinc-200 transition hover:border-zinc-500 hover:bg-zinc-900 focus:outline-none focus:ring-2 focus:ring-zinc-500 focus:ring-offset-2 focus:ring-offset-zinc-950" %>
      <%= link_to "Users", users_path, class: "inline-flex items-center justify-center rounded-md border border-zinc-700 px-4 py-2 text-sm font-semibold text-zinc-200 transition hover:border-zinc-500 hover:bg-zinc-900 focus:outline-none focus:ring-2 focus:ring-zinc-500 focus:ring-offset-2 focus:ring-offset-zinc-950" %>
      <% unless @configuration_error.present? %>
        <%= button_to @active_refresh_run ? "Refresh running" : "Refresh from Plex",
          refresh_shares_path,
          disabled: @active_refresh_run.present?,
          data: { turbo: false },
          class: "inline-flex items-center justify-center rounded-md bg-cyan-300 px-4 py-2 text-sm font-semibold text-zinc-950 transition hover:bg-cyan-200 focus:outline-none focus:ring-2 focus:ring-cyan-200 focus:ring-offset-2 focus:ring-offset-zinc-950 disabled:cursor-not-allowed disabled:opacity-50" %>
      <% end %>
      <%= button_to "Sign out", sign_out_path, method: :delete, class: "inline-flex items-center justify-center rounded-md border border-zinc-700 px-4 py-2 text-sm font-semibold text-zinc-200 transition hover:border-zinc-500 hover:bg-zinc-900 focus:outline-none focus:ring-2 focus:ring-zinc-500 focus:ring-offset-2 focus:ring-offset-zinc-950" %>
    </div>
  </header>

  <% if @refresh_run.present? %>
    <section class="rounded-lg border border-zinc-800 bg-zinc-950 p-5">
      <div class="flex flex-col gap-3 lg:flex-row lg:items-start lg:justify-between">
        <div>
          <p class="text-xs font-semibold uppercase tracking-wide text-zinc-500">Refresh status</p>
          <p class="mt-2 text-lg font-semibold text-white"><%= @refresh_run.label %></p>
          <p class="mt-1 text-sm text-zinc-400"><%= @refresh_run.last_message.presence || "Waiting for progress" %></p>
          <% if @refresh_run.error_message.present? %>
            <p class="mt-2 text-sm text-red-100"><%= @refresh_run.error_message %></p>
          <% end %>
        </div>
        <dl class="grid gap-2 text-xs text-zinc-400 sm:grid-cols-2 lg:min-w-[32rem]">
          <div><dt class="inline text-zinc-500">Queued by:</dt> <dd class="inline"><%= @refresh_run.admin_email.presence || "unknown" %></dd></div>
          <div><dt class="inline text-zinc-500">Elapsed:</dt> <dd class="inline"><%= @refresh_run.elapsed_seconds ? distance_of_time_in_words(@refresh_run.elapsed_seconds) : "not started" %></dd></div>
          <div><dt class="inline text-zinc-500">History pages:</dt> <dd class="inline"><%= @refresh_run.history_pages_retrieved %></dd></div>
          <div><dt class="inline text-zinc-500">History rows:</dt> <dd class="inline"><%= number_with_delimiter(@refresh_run.history_rows_retrieved) %></dd></div>
          <div><dt class="inline text-zinc-500">Users matched:</dt> <dd class="inline"><%= @refresh_run.history_users_matched %></dd></div>
          <div><dt class="inline text-zinc-500">Users remaining:</dt> <dd class="inline"><%= @refresh_run.history_users_remaining %></dd></div>
          <% if @refresh_run.account_lookups_total.positive? %>
            <div class="sm:col-span-2"><dt class="inline text-zinc-500">Account lookups:</dt> <dd class="inline"><%= @refresh_run.account_lookups_completed %>/<%= @refresh_run.account_lookups_total %></dd></div>
          <% end %>
        </dl>
      </div>
    </section>
  <% end %>

  <% if @configuration_error.present? %>
    <section class="rounded-lg border border-amber-500/40 bg-amber-950/40 p-5">
      <h2 class="text-lg font-semibold text-amber-100">Configuration needed</h2>
      <p class="mt-2 text-sm leading-6 text-amber-50/80"><%= @configuration_error %></p>
      <p class="mt-4 text-sm leading-6 text-amber-50/80">
        Create <code class="rounded bg-black/30 px-1.5 py-0.5">.env</code> from
        <code class="rounded bg-black/30 px-1.5 py-0.5">.env.example</code>, then add your Plex token and machine identifier.
      </p>
    </section>
  <% elsif @plex_error.present? %>
    <section class="rounded-lg border border-red-500/40 bg-red-950/40 p-5">
      <h2 class="text-lg font-semibold text-red-100">Could not load Plex shares</h2>
      <p class="mt-2 text-sm leading-6 text-red-50/80"><%= @plex_error %></p>
    </section>
  <% elsif @report.blank? %>
    <section class="rounded-lg border border-zinc-800 bg-zinc-900 p-5">
      <p class="text-sm leading-6 text-zinc-400">No local snapshot yet. Queue a Plex refresh to fetch sharing data.</p>
    </section>
  <% else %>
    <section class="grid gap-3 sm:grid-cols-2 lg:grid-cols-4">
      <div class="rounded-lg border border-zinc-800 bg-zinc-900 p-4">
        <p class="text-xs font-medium uppercase tracking-wide text-zinc-500">Server</p>
        <p class="mt-2 text-lg font-semibold text-white"><%= @report.server[:name].presence || "Configured server" %></p>
      </div>
      <div class="rounded-lg border border-zinc-800 bg-zinc-900 p-4">
        <p class="text-xs font-medium uppercase tracking-wide text-zinc-500">Users</p>
        <p class="mt-2 text-lg font-semibold text-white"><%= @report.users.size %></p>
      </div>
      <div class="rounded-lg border border-zinc-800 bg-zinc-900 p-4">
        <p class="text-xs font-medium uppercase tracking-wide text-zinc-500">Libraries</p>
        <p class="mt-2 text-lg font-semibold text-white"><%= @report.libraries.size %></p>
      </div>
      <div class="rounded-lg border border-zinc-800 bg-zinc-900 p-4">
        <p class="text-xs font-medium uppercase tracking-wide text-zinc-500">Fetched</p>
        <p class="mt-2 text-lg font-semibold text-white"><%= l(@report.generated_at, format: :short) %></p>
      </div>
    </section>

    <details class="rounded-lg border border-zinc-800 bg-zinc-950 p-5">
      <summary class="cursor-pointer list-none text-lg font-semibold text-white">
        <span class="inline-flex items-center gap-2">
          <span class="text-cyan-300">+</span>
          Grant library access
        </span>
      </summary>
      <p class="mt-2 text-sm text-zinc-400">Send a Plex invite by username or email, then choose the libraries to share.</p>

      <%= form_with url: shares_path, method: :post, class: "mt-4 grid gap-4 lg:grid-cols-[minmax(16rem,24rem)_1fr_auto]" do %>
        <div>
          <label for="invited_email" class="text-xs font-semibold uppercase tracking-wide text-zinc-500">Username or email</label>
          <%= text_field_tag :invited_email,
            nil,
            id: "invited_email",
            required: true,
            autocomplete: "off",
            placeholder: "friend@example.com",
            class: "mt-2 w-full rounded-md border border-zinc-700 bg-zinc-900 px-3 py-2 text-sm text-zinc-100 focus:border-cyan-300 focus:outline-none focus:ring-2 focus:ring-cyan-300/30" %>
          <label class="mt-3 flex items-center gap-2 text-sm text-zinc-300">
            <%= check_box_tag :allow_sync, "1", false, class: "size-4 rounded border-zinc-700 bg-zinc-950 text-cyan-300 focus:ring-cyan-300/30" %>
            Allow downloads
          </label>
        </div>

        <div>
          <p class="text-xs font-semibold uppercase tracking-wide text-zinc-500">Libraries</p>
          <div class="mt-2 grid gap-2 sm:grid-cols-2 lg:grid-cols-3">
            <% @report.libraries.each do |library| %>
              <% input_id = "new_share_library_#{library.id}" %>
              <label for="<%= input_id %>" class="flex min-h-10 cursor-pointer items-start gap-2 rounded-md border border-zinc-700 bg-zinc-900 px-3 py-2 text-xs text-zinc-200 transition hover:border-zinc-500">
                <%= check_box_tag "library_ids[]",
                  library.id,
                  true,
                  id: input_id,
                  class: "mt-0.5 size-4 rounded border-zinc-700 bg-zinc-950 text-cyan-300 focus:ring-cyan-300/30" %>
                <span class="min-w-0">
                  <span class="block truncate font-semibold text-zinc-100"><%= library.title %></span>
                  <span class="block text-zinc-500"><%= library.type %></span>
                </span>
              </label>
            <% end %>
          </div>
        </div>

        <div class="flex items-end">
          <button type="submit" class="inline-flex w-full items-center justify-center rounded-md bg-cyan-300 px-4 py-2 text-sm font-semibold text-zinc-950 transition hover:bg-cyan-200 focus:outline-none focus:ring-2 focus:ring-cyan-200 focus:ring-offset-2 focus:ring-offset-zinc-950">Send invite</button>
        </div>
      <% end %>
    </details>

    <section class="overflow-hidden rounded-lg border border-zinc-800 bg-zinc-950" data-controller="confirmation">
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-zinc-800 text-left text-sm">
          <thead class="bg-zinc-900/80 text-xs uppercase tracking-wide text-zinc-400">
            <tr>
              <th class="px-4 py-3 font-semibold">User</th>
              <th class="px-4 py-3 font-semibold">Status</th>
              <th class="px-4 py-3 font-semibold">Metadata</th>
              <th class="px-4 py-3 font-semibold">Libraries</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-zinc-800">
            <% @report.users.each do |user| %>
              <% note = @notes_by_user_id[user.id.to_s] %>
              <tr class="align-top">
                <td class="min-w-72 px-4 py-4">
                  <div class="flex items-center gap-3">
                    <% if user.share_id.present? %>
                      <%= button_to "x",
                        share_path(user.share_id),
                        method: :delete,
                        form: {
                          data: {
                            action: "submit->confirmation#confirmSubmit",
                            confirm_title: "Remove #{user.label}?",
                            confirm_body: "This will revoke #{user.label}'s access to all libraries on this Plex server.",
                            confirm_button: "Remove user"
                          }
                        },
                        aria: { label: "Remove #{user.label} from all libraries" },
                        class: "inline-flex size-7 shrink-0 items-center justify-center rounded-md border border-red-500/40 text-sm font-semibold leading-none text-red-100 transition hover:bg-red-950 focus:outline-none focus:ring-2 focus:ring-red-300 focus:ring-offset-2 focus:ring-offset-zinc-950" %>
                    <% else %>
                      <span class="size-7 shrink-0" aria-hidden="true"></span>
                    <% end %>
                    <% if user.thumb.present? %>
                      <img src="<%= user.thumb %>" alt="" class="size-10 rounded-md bg-zinc-800 object-cover">
                    <% else %>
                      <div class="flex size-10 items-center justify-center rounded-md bg-zinc-800 text-sm font-semibold text-zinc-300">
                        <%= user.label.first.to_s.upcase %>
                      </div>
                    <% end %>
                    <div class="min-w-0">
                      <p class="font-semibold text-white"><%= link_to user.label, user_path(user.id), class: "hover:text-cyan-300" %></p>
                      <p class="truncate text-xs text-zinc-500"><%= user.email.presence || user.username %></p>
                    </div>
                  </div>
                  <% if note&.notes.present? %>
                    <div class="mt-3 rounded-md border border-zinc-800 bg-zinc-900/70 p-3 text-xs leading-5 text-zinc-300">
                      <p class="whitespace-pre-wrap"><%= note.notes %></p>
                      <% if note.updated_at.present? %>
                        <p class="mt-2 text-[11px] uppercase tracking-wide text-zinc-500">
                          Updated <%= time_ago_in_words(note.updated_at) %> ago
                        </p>
                      <% end %>
                    </div>
                  <% end %>
                  <details class="mt-3">
                    <summary class="cursor-pointer list-none text-xs font-semibold text-cyan-300">Edit notes</summary>
                    <%= form_with scope: :plex_user_note, url: user_note_path(user.id), method: :patch, class: "mt-2 flex items-start gap-2" do |form| %>
                      <%= hidden_field_tag :return_to, root_path %>
                      <%= form.hidden_field :username, value: user.username %>
                      <%= form.hidden_field :email, value: user.email %>
                      <%= form.text_area :notes,
                        value: note&.notes,
                        rows: 3,
                        placeholder: "Local admin notes",
                        class: "min-h-16 w-full rounded-md border border-zinc-700 bg-zinc-900 px-3 py-2 text-sm text-zinc-100 focus:border-cyan-300 focus:outline-none focus:ring-2 focus:ring-cyan-300/30" %>
                      <button type="submit" class="inline-flex shrink-0 items-center justify-center rounded-md bg-cyan-300 px-3 py-2 text-xs font-semibold text-zinc-950 transition hover:bg-cyan-200 focus:outline-none focus:ring-2 focus:ring-cyan-200 focus:ring-offset-2 focus:ring-offset-zinc-950">Save</button>
                    <% end %>
                  </details>
                </td>
                <td class="px-4 py-4">
                  <% if user.pending %>
                    <span class="inline-flex rounded-md border border-amber-400/30 bg-amber-400/10 px-2 py-1 text-xs font-semibold text-amber-200">Pending</span>
                  <% else %>
                    <span class="inline-flex rounded-md border border-emerald-400/30 bg-emerald-400/10 px-2 py-1 text-xs font-semibold text-emerald-200">Active</span>
                  <% end %>
                  <% if user.all_libraries %>
                    <span class="ml-2 inline-flex rounded-md border border-cyan-300/30 bg-cyan-300/10 px-2 py-1 text-xs font-semibold text-cyan-100">All</span>
                  <% end %>
                </td>
                <td class="px-4 py-4">
                  <dl class="grid gap-1 text-xs text-zinc-400">
                    <div><dt class="inline text-zinc-500">User ID:</dt> <dd class="inline"><%= user.id %></dd></div>
                    <div><dt class="inline text-zinc-500">Share ID:</dt> <dd class="inline"><%= user.share_id.presence || "unknown" %></dd></div>
                    <% if user.pending && user.invited_at.present? %>
                      <div><dt class="inline text-zinc-500">Invited:</dt> <dd class="inline"><%= optional_plex_timestamp(user.invited_at) %></dd></div>
                    <% end %>
                    <div><dt class="inline text-zinc-500">Last streamed:</dt> <dd class="inline"><%= optional_plex_timestamp(user.last_streamed_at) %></dd></div>
                    <% if user.last_streamed_title.present? %>
                      <div><dt class="inline text-zinc-500">Last title:</dt> <dd class="inline"><%= user.last_streamed_title %></dd></div>
                    <% end %>
                    <div><dt class="inline text-zinc-500">Home:</dt> <dd class="inline"><%= user.home ? "yes" : "no" %></dd></div>
                    <div><dt class="inline text-zinc-500">Sync:</dt> <dd class="inline"><%= user.allow_sync ? "allowed" : "off" %></dd></div>
                  </dl>
                </td>
                <td class="px-4 py-4">
                  <% if user.share_id.present? %>
                    <p class="text-xs text-zinc-400"><%= user.libraries.map(&:title).to_sentence.presence || "No libraries selected" %></p>
                    <details class="mt-2 max-w-xl">
                      <summary class="cursor-pointer list-none text-xs font-semibold text-cyan-300">Manage libraries</summary>
                      <%= form_with url: share_path(user.share_id),
                        method: :patch,
                        class: "mt-2",
                        data: {
                          action: "submit->confirmation#confirmSubmit",
                          confirm_when_empty: "true",
                          confirm_title: "Remove Plex share?",
                          confirm_body: "Saving with no libraries selected will revoke this user's access to this Plex server.",
                          confirm_button: "Remove share"
                        } do %>
                        <% selected_library_ids = user.libraries.map { |library| library.id.to_s } %>
                        <div class="grid gap-2 sm:grid-cols-2">
                          <% @report.libraries.each do |library| %>
                            <% input_id = "share_#{user.share_id}_library_#{library.id}" %>
                            <label for="<%= input_id %>" class="flex min-h-10 cursor-pointer items-start gap-2 rounded-md border border-zinc-700 bg-zinc-900 px-3 py-2 text-xs text-zinc-200 transition hover:border-zinc-500">
                              <%= check_box_tag "library_ids[]",
                                library.id,
                                selected_library_ids.include?(library.id.to_s),
                                id: input_id,
                                class: "mt-0.5 size-4 rounded border-zinc-700 bg-zinc-950 text-cyan-300 focus:ring-cyan-300/30" %>
                              <span class="min-w-0">
                                <span class="block truncate font-semibold text-zinc-100"><%= library.title %></span>
                                <span class="block text-zinc-500"><%= library.type %></span>
                              </span>
                            </label>
                          <% end %>
                        </div>
                        <p class="mt-1 text-xs text-zinc-500">Saving with no libraries checked revokes this server share.</p>
                        <div class="mt-3 flex flex-wrap gap-2">
                          <button type="submit" class="inline-flex items-center justify-center rounded-md bg-cyan-300 px-3 py-2 text-xs font-semibold text-zinc-950 transition hover:bg-cyan-200 focus:outline-none focus:ring-2 focus:ring-cyan-200 focus:ring-offset-2 focus:ring-offset-zinc-950">Save libraries</button>
                        </div>
                      <% end %>
                    </details>
                  <% else %>
                    <% if user.pending %>
                      <p class="text-xs leading-5 text-zinc-400">
                        Pending invite for <%= pluralize(user.library_count, "library") %>.
                        <% if user.libraries.any? %>
                          <span class="block text-zinc-500"><%= user.libraries.map(&:title).to_sentence %></span>
                        <% else %>
                          <span class="block text-zinc-500">Plex does not expose the exact pending library list here.</span>
                        <% end %>
                      </p>
                    <% else %>
                      <p class="text-xs leading-5 text-zinc-500">This user did not include a Plex share id in the snapshot, so library edits are unavailable.</p>
                    <% end %>
                  <% end %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
      <dialog data-confirmation-target="dialog" class="w-[calc(100%-2rem)] max-w-md rounded-lg border border-zinc-700 bg-zinc-950 p-0 text-zinc-100 shadow-2xl backdrop:bg-black/70">
        <div class="p-5">
          <h2 data-confirmation-target="title" class="text-lg font-semibold text-white">Confirm action</h2>
          <p data-confirmation-target="body" class="mt-2 text-sm leading-6 text-zinc-400">This action cannot be undone.</p>
          <div class="mt-5 flex justify-end gap-2">
            <button type="button" data-action="confirmation#cancel" class="inline-flex items-center justify-center rounded-md border border-zinc-700 px-4 py-2 text-sm font-semibold text-zinc-200 transition hover:border-zinc-500 hover:bg-zinc-900 focus:outline-none focus:ring-2 focus:ring-zinc-500 focus:ring-offset-2 focus:ring-offset-zinc-950">Cancel</button>
            <button type="button" data-confirmation-target="confirmButton" data-action="confirmation#submit" class="inline-flex items-center justify-center rounded-md bg-red-300 px-4 py-2 text-sm font-semibold text-red-950 transition hover:bg-red-100 focus:outline-none focus:ring-2 focus:ring-red-300 focus:ring-offset-2 focus:ring-offset-zinc-950">Confirm</button>
          </div>
        </div>
      </dialog>
    </section>
  <% end %>
</div>
