<% content_for :title, "Plex Now Playing" %>

<div class="mx-auto flex w-full max-w-[100rem] flex-col gap-6 px-4 py-6 sm:px-6 lg:px-8">
  <header class="flex min-h-16 flex-col gap-4 border-b border-zinc-800 pb-5 sm:flex-row sm:items-center sm:justify-between">
    <div class="flex min-w-0 flex-wrap items-baseline gap-x-3 gap-y-1">
      <h1 class="text-3xl font-semibold tracking-normal text-white">Now Playing</h1>
      <span class="text-sm text-zinc-400">Auto-refreshes every 10 seconds</span>
    </div>
    <%= render "shared/page_nav" %>
  </header>

  <nav class="flex justify-end gap-2" aria-label="Now playing view">
    <% compact = @view_mode == "compact" %>
    <%= link_to "▦",
      now_playing_path(view: "tiles"),
      class: [
        "inline-flex size-10 cursor-pointer items-center justify-center rounded-md border text-lg font-semibold transition focus:outline-none focus:ring-2 focus:ring-cyan-200 focus:ring-offset-2 focus:ring-offset-zinc-950",
        compact ? "border-zinc-700 text-zinc-200 hover:border-zinc-500 hover:bg-zinc-900 hover:text-white" : "border-cyan-300 bg-cyan-300 text-zinc-950"
      ].join(" "),
      aria: { label: "Tile view", current: compact ? nil : "page" },
      title: "Tile view" %>
    <%= link_to "☰",
      now_playing_path(view: "compact"),
      class: [
        "inline-flex size-10 cursor-pointer items-center justify-center rounded-md border text-lg font-semibold transition focus:outline-none focus:ring-2 focus:ring-cyan-200 focus:ring-offset-2 focus:ring-offset-zinc-950",
        compact ? "border-cyan-300 bg-cyan-300 text-zinc-950" : "border-zinc-700 text-zinc-200 hover:border-zinc-500 hover:bg-zinc-900 hover:text-white"
      ].join(" "),
      aria: { label: "Compact list view", current: compact ? "page" : nil },
      title: "Compact list view" %>
  </nav>

  <div
    data-controller="auto-refresh"
    data-auto-refresh-interval-value="10000"
    data-auto-refresh-url-value="<%= now_playing_path(partial: 1, view: @view_mode) %>">
    <%= render "sessions" %>
  </div>
</div>
