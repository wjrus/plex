<% if @plex_error.present? %>
  <section class="rounded-lg border border-amber-500/40 bg-amber-950/40 p-5">
    <h2 class="text-lg font-semibold text-amber-100">Unavailable</h2>
    <p class="mt-2 text-sm leading-6 text-amber-50/80"><%= @plex_error %></p>
  </section>
<% elsif @sessions.empty? %>
  <section class="rounded-lg border border-zinc-800 bg-zinc-950 p-5">
    <p class="text-sm leading-6 text-zinc-400">Nothing is currently streaming.</p>
    <% if @fetched_at.present? %>
      <p class="mt-2 text-xs text-zinc-500">Checked <%= l(@fetched_at, format: :short) %></p>
    <% end %>
  </section>
<% else %>
  <div class="mb-1 flex justify-end text-xs text-zinc-500">
    <span>Checked <%= l(@fetched_at, format: :short) %></span>
  </div>
  <section class="grid gap-4 lg:grid-cols-2">
    <% @sessions.each do |stream| %>
      <% progress = Plex::StreamFormatter.progress_percent(stream) %>
      <% cover_url = plex_image_url(Plex::StreamFormatter.cover_path(stream)) %>
      <article class="rounded-lg border border-zinc-800 bg-zinc-950 p-5">
        <div class="grid gap-4">
          <div class="flex gap-4">
            <div class="w-[7.25rem] shrink-0 overflow-hidden rounded-md border border-zinc-800 bg-zinc-900 aspect-[2/3]">
              <% if cover_url.present? %>
                <img src="<%= cover_url %>" alt="" class="h-full w-full object-cover">
              <% end %>
            </div>
            <div class="min-w-0 flex-1">
              <div class="grid min-w-0 grid-cols-[minmax(0,1fr)_auto] items-start gap-3">
                <div class="min-w-0">
                  <h2 class="truncate text-lg font-semibold text-white"><%= Plex::StreamFormatter.title(stream).presence || stream[:title].presence || "Unknown title" %></h2>
                  <p class="mt-1 text-sm text-zinc-400"><%= Plex::StreamFormatter.user_label(stream) %></p>
                </div>
                <span class="inline-flex rounded-md border border-cyan-300/30 bg-cyan-300/10 px-2 py-1 text-xs font-semibold text-cyan-100">
                  <%= Plex::StreamFormatter.state(stream).titleize %>
                </span>
              </div>

              <dl class="mt-4 grid gap-2 text-sm text-zinc-400">
                <div><dt class="inline text-zinc-500">Player:</dt> <dd class="inline"><%= Plex::StreamFormatter.player_label(stream) %></dd></div>
                <div><dt class="inline text-zinc-500">Library:</dt> <dd class="inline"><%= stream[:library_section_title].presence || "unknown" %></dd></div>
                <div><dt class="inline text-zinc-500">Type:</dt> <dd class="inline"><%= stream[:type].presence || "unknown" %></dd></div>
                <% if stream.dig(:session, :id).present? %>
                  <div><dt class="inline text-zinc-500">Session:</dt> <dd class="inline break-all"><%= stream.dig(:session, :id) %></dd></div>
                <% end %>
              </dl>
            </div>
          </div>

          <% if progress.positive? %>
            <div>
              <div class="h-2 overflow-hidden rounded bg-zinc-800">
                <div class="h-full bg-cyan-300" style="width: <%= progress %>%"></div>
              </div>
              <p class="mt-2 text-xs text-zinc-500"><%= progress %>% complete</p>
            </div>
          <% end %>
        </div>
      </article>
    <% end %>
  </section>
<% end %>
