<% if @plex_error.present? %>
  <section class="rounded-lg border border-amber-500/40 bg-amber-950/40 p-5">
    <h2 class="text-lg font-semibold text-amber-100">Unavailable</h2>
    <p class="mt-2 text-sm leading-6 text-amber-50/80"><%= @plex_error %></p>
  </section>
<% elsif @sessions.empty? %>
  <section class="rounded-lg border border-zinc-800 bg-zinc-950 p-5">
    <p class="text-sm leading-6 text-zinc-400">Nothing is currently streaming.</p>
    <% if @fetched_at.present? %>
      <p class="mt-2 text-xs text-zinc-500">Checked <%= l(@fetched_at, format: :short) %></p>
    <% end %>
  </section>
<% else %>
  <div class="mb-2 flex justify-end text-xs text-zinc-500">
    <span>Checked <%= l(@fetched_at, format: :short) %></span>
  </div>

  <% session_groups = [
    [ "Playing", @playing_sessions, pluralize(@playing_sessions.size, "active stream") ],
    [ "Paused", @paused_sessions, pluralize(@paused_sessions.size, "paused stream") ],
    [ "Other", @other_sessions, pluralize(@other_sessions.size, "other session") ]
  ] %>

  <div class="grid gap-8">
    <% session_groups.each do |heading, streams, subtitle| %>
      <% next if streams.empty? %>

      <section class="grid gap-3">
        <div class="flex flex-col gap-2 border-b border-zinc-800 pb-3 sm:flex-row sm:items-end sm:justify-between">
          <div>
            <h2 class="text-xl font-semibold text-white"><%= heading %></h2>
            <p class="mt-1 text-sm text-zinc-400"><%= subtitle %></p>
          </div>
          <p class="text-xs text-zinc-500">Newest first</p>
        </div>

        <% if @view_mode == "compact" %>
          <div class="overflow-hidden rounded-lg border border-zinc-800 bg-zinc-950">
            <table class="min-w-full divide-y divide-zinc-800 text-left text-sm">
              <thead class="bg-zinc-900/80 text-xs uppercase tracking-wide text-zinc-400">
                <tr>
                  <th class="px-4 py-3 font-semibold">Title</th>
                  <th class="px-4 py-3 font-semibold">User</th>
                  <th class="px-4 py-3 font-semibold">Player</th>
                  <th class="px-4 py-3 font-semibold">IP</th>
                  <th class="px-4 py-3 font-semibold">Progress</th>
                  <th class="px-4 py-3 font-semibold">Started</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-zinc-800">
                <% streams.each do |stream| %>
                  <% progress = Plex::StreamFormatter.progress_percent(stream) %>
                  <% started_at = Plex::StreamFormatter.started_at(stream) %>
                  <tr>
                    <td class="min-w-72 px-4 py-3">
                      <p class="font-medium text-white"><%= Plex::StreamFormatter.title(stream).presence || stream[:title].presence || "Unknown title" %></p>
                      <p class="mt-1 text-xs text-zinc-500"><%= stream[:library_section_title].presence || "unknown" %> · <%= stream[:type].presence || "unknown" %></p>
                    </td>
                    <td class="px-4 py-3 text-zinc-300"><%= Plex::StreamFormatter.user_label(stream) %></td>
                    <td class="px-4 py-3 text-zinc-300"><%= Plex::StreamFormatter.player_label(stream) %></td>
                    <td class="px-4 py-3 text-zinc-400"><%= Plex::StreamFormatter.ip_address(stream).presence || "Unknown" %></td>
                    <td class="min-w-40 px-4 py-3 text-zinc-300">
                      <div class="h-2 overflow-hidden rounded bg-zinc-800">
                        <div class="h-full bg-cyan-300" style="width: <%= progress %>%"></div>
                      </div>
                      <p class="mt-1 text-xs text-zinc-500"><%= progress %>%</p>
                    </td>
                    <td class="whitespace-nowrap px-4 py-3 text-zinc-400"><%= l(started_at, format: :short) %></td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        <% else %>
          <div class="grid gap-4 lg:grid-cols-2">
            <% streams.each do |stream| %>
              <% progress = Plex::StreamFormatter.progress_percent(stream) %>
              <% cover_url = plex_image_url(Plex::StreamFormatter.cover_path(stream)) %>
              <% started_at = Plex::StreamFormatter.started_at(stream) %>
              <article class="rounded-lg border border-zinc-800 bg-zinc-950 p-5">
                <div class="grid gap-4">
                  <div class="flex gap-4">
                    <div class="w-[7.25rem] shrink-0 overflow-hidden rounded-md border border-zinc-800 bg-zinc-900 aspect-[2/3]">
                      <% if cover_url.present? %>
                        <img src="<%= cover_url %>" alt="" class="h-full w-full object-cover">
                      <% end %>
                    </div>
                    <div class="min-w-0 flex-1">
                      <div class="grid min-w-0 grid-cols-[minmax(0,1fr)_auto] items-start gap-3">
                        <div class="min-w-0">
                          <h3 class="truncate pr-2 text-lg font-semibold text-white"><%= Plex::StreamFormatter.title(stream).presence || stream[:title].presence || "Unknown title" %></h3>
                          <p class="mt-1 text-sm text-zinc-400"><%= Plex::StreamFormatter.user_label(stream) %></p>
                        </div>
                        <span class="inline-flex shrink-0 rounded-md border border-cyan-300/30 bg-cyan-300/10 px-2 py-1 text-xs font-semibold text-cyan-100">
                          <%= Plex::StreamFormatter.state(stream).titleize %>
                        </span>
                      </div>

                      <dl class="mt-4 grid gap-2 text-sm text-zinc-400">
                        <div><dt class="inline text-zinc-500">Started:</dt> <dd class="inline"><%= l(started_at, format: :short) %></dd></div>
                        <div><dt class="inline text-zinc-500">Player:</dt> <dd class="inline"><%= Plex::StreamFormatter.player_label(stream) %></dd></div>
                        <div><dt class="inline text-zinc-500">IP:</dt> <dd class="inline"><%= Plex::StreamFormatter.ip_address(stream).presence || "Unknown" %></dd></div>
                        <div><dt class="inline text-zinc-500">Library:</dt> <dd class="inline"><%= stream[:library_section_title].presence || "unknown" %></dd></div>
                        <div><dt class="inline text-zinc-500">Type:</dt> <dd class="inline"><%= stream[:type].presence || "unknown" %></dd></div>
                        <% if stream.dig(:session, :id).present? %>
                          <div><dt class="inline text-zinc-500">Session:</dt> <dd class="inline break-all"><%= stream.dig(:session, :id) %></dd></div>
                        <% end %>
                      </dl>
                    </div>
                  </div>

                  <div>
                    <div class="h-2 overflow-hidden rounded bg-zinc-800">
                      <div class="h-full bg-cyan-300" style="width: <%= progress %>%"></div>
                    </div>
                    <p class="mt-2 text-xs text-zinc-500"><%= progress %>% complete</p>
                  </div>
                </div>
              </article>
            <% end %>
          </div>
        <% end %>
      </section>
    <% end %>
  </div>
<% end %>
