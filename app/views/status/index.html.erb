<% content_for :title, "Plex Status" %>

<div class="mx-auto flex w-full max-w-[100rem] flex-col gap-6 px-4 py-6 sm:px-6 lg:px-8">
  <header class="flex min-h-16 flex-col gap-4 border-b border-zinc-800 pb-5 sm:flex-row sm:items-center sm:justify-between">
    <div class="flex min-w-0 flex-wrap items-baseline gap-x-3 gap-y-1">
      <h1 class="text-3xl font-semibold tracking-normal text-white">Status</h1>
    </div>
    <%= render "shared/page_nav" %>
  </header>

  <section class="grid gap-3 sm:grid-cols-2 xl:grid-cols-4">
    <div class="rounded-lg border border-zinc-800 bg-zinc-950 p-4">
      <p class="text-xs font-medium uppercase tracking-wide text-zinc-500">Revision</p>
      <p class="mt-2 text-lg font-semibold text-white"><%= @app_revision %></p>
    </div>
    <div class="rounded-lg border border-zinc-800 bg-zinc-950 p-4">
      <p class="text-xs font-medium uppercase tracking-wide text-zinc-500">Database</p>
      <p class="mt-2 text-lg font-semibold text-white"><%= @database_ok ? "Connected" : "Unavailable" %></p>
    </div>
    <div class="rounded-lg border border-zinc-800 bg-zinc-950 p-4">
      <p class="text-xs font-medium uppercase tracking-wide text-zinc-500">Latest Snapshot</p>
      <p class="mt-2 text-lg font-semibold text-white"><%= @latest_snapshot ? l(@latest_snapshot.fetched_at, format: :short) : "None" %></p>
    </div>
    <div class="rounded-lg border border-zinc-800 bg-zinc-950 p-4">
      <p class="text-xs font-medium uppercase tracking-wide text-zinc-500">Active Refresh</p>
      <p class="mt-2 text-lg font-semibold text-white"><%= @active_refresh_run&.label || "None" %></p>
    </div>
    <div class="rounded-lg border border-zinc-800 bg-zinc-950 p-4">
      <p class="text-xs font-medium uppercase tracking-wide text-zinc-500">Last Completed</p>
      <p class="mt-2 text-lg font-semibold text-white"><%= @last_completed_refresh&.finished_at ? l(@last_completed_refresh.finished_at, format: :short) : "None" %></p>
    </div>
    <div class="rounded-lg border border-zinc-800 bg-zinc-950 p-4">
      <p class="text-xs font-medium uppercase tracking-wide text-zinc-500">Next Scheduled</p>
      <p class="mt-2 text-lg font-semibold text-white"><%= @next_daily_refresh_at ? l(@next_daily_refresh_at, format: :short) : "Unknown" %></p>
    </div>
    <div class="rounded-lg border border-zinc-800 bg-zinc-950 p-4">
      <p class="text-xs font-medium uppercase tracking-wide text-zinc-500">Latest Run</p>
      <p class="mt-2 text-lg font-semibold text-white"><%= @latest_refresh&.label || "None" %></p>
    </div>
  </section>

  <section class="grid gap-4 lg:grid-cols-2">
    <div class="rounded-lg border border-zinc-800 bg-zinc-950 p-5">
      <div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between">
        <div>
          <h2 class="text-lg font-semibold text-white">Refresh</h2>
          <p class="mt-1 text-sm text-zinc-400">Daily auto-refresh runs in the background. Queue a manual Plex refresh here when needed.</p>
        </div>
        <%= form_with url: refresh_shares_path, method: :post, data: { turbo: false }, class: "grid shrink-0 gap-2" do %>
          <label class="flex items-center gap-2 text-xs text-zinc-400">
            <%= check_box_tag :include_history,
              "1",
              false,
              disabled: @active_refresh_run.present?,
              class: "size-4 rounded border-zinc-700 bg-zinc-950 text-cyan-300 focus:ring-cyan-300/30" %>
            Include playback history
          </label>
          <button type="submit" <%= "disabled" if @active_refresh_run.present? %> class="inline-flex items-center justify-center rounded-md bg-cyan-300 px-4 py-2 text-sm font-semibold text-zinc-950 transition hover:bg-cyan-200 focus:outline-none focus:ring-2 focus:ring-cyan-200 focus:ring-offset-2 focus:ring-offset-zinc-950 disabled:cursor-not-allowed disabled:opacity-50">
            <%= @active_refresh_run ? "Refresh running" : "Refresh from Plex" %>
          </button>
        <% end %>
      </div>
      <% if @latest_refresh %>
        <% if @latest_refresh.stale? %>
          <div class="mt-4 rounded-md border border-amber-400/30 bg-amber-400/10 p-3 text-sm text-amber-200">
            This refresh stopped reporting progress and was marked stale. It was probably interrupted by a deploy or worker restart.
          </div>
        <% end %>
        <dl class="mt-4 grid gap-2 text-sm text-zinc-400">
          <div><dt class="inline text-zinc-500">Status:</dt> <dd class="inline"><%= @latest_refresh.label %></dd></div>
          <div><dt class="inline text-zinc-500">Queued by:</dt> <dd class="inline"><%= @latest_refresh.admin_email.presence || "unknown" %></dd></div>
          <div><dt class="inline text-zinc-500">Message:</dt> <dd class="inline"><%= @latest_refresh.last_message.presence || "none" %></dd></div>
          <div><dt class="inline text-zinc-500">Started:</dt> <dd class="inline"><%= @latest_refresh.started_at ? l(@latest_refresh.started_at, format: :long) : "not started" %></dd></div>
          <div><dt class="inline text-zinc-500">Last heartbeat:</dt> <dd class="inline"><%= l(@latest_refresh.updated_at, format: :long) %></dd></div>
          <div><dt class="inline text-zinc-500">Finished:</dt> <dd class="inline"><%= @latest_refresh.finished_at ? l(@latest_refresh.finished_at, format: :long) : "not finished" %></dd></div>
          <div><dt class="inline text-zinc-500">Elapsed:</dt> <dd class="inline"><%= @latest_refresh.started_at ? distance_of_time_in_words(@latest_refresh.started_at, @latest_refresh.finished_at || Time.current) : "unknown" %></dd></div>
          <div><dt class="inline text-zinc-500">History:</dt> <dd class="inline"><%= @latest_refresh.include_history ? "included" : "not included" %></dd></div>
          <div><dt class="inline text-zinc-500">History pages:</dt> <dd class="inline"><%= @latest_refresh.history_pages_retrieved %></dd></div>
          <div><dt class="inline text-zinc-500">History rows:</dt> <dd class="inline"><%= number_with_delimiter(@latest_refresh.history_rows_retrieved) %></dd></div>
          <div><dt class="inline text-zinc-500">Users matched:</dt> <dd class="inline"><%= @latest_refresh.history_users_matched %></dd></div>
          <div><dt class="inline text-zinc-500">Users remaining:</dt> <dd class="inline"><%= @latest_refresh.history_users_remaining %></dd></div>
          <% if @latest_refresh.account_lookups_total.positive? %>
            <div><dt class="inline text-zinc-500">Account lookups:</dt> <dd class="inline"><%= @latest_refresh.account_lookups_completed %>/<%= @latest_refresh.account_lookups_total %></dd></div>
          <% end %>
          <% if @latest_refresh.error_message.present? %>
            <div><dt class="inline text-zinc-500">Error:</dt> <dd class="inline"><%= @latest_refresh.error_message %></dd></div>
          <% end %>
        </dl>
      <% else %>
        <p class="mt-3 text-sm text-zinc-400">No refresh has been queued yet.</p>
      <% end %>
    </div>

    <div class="rounded-lg border border-zinc-800 bg-zinc-950 p-5">
      <h2 class="text-lg font-semibold text-white">Last Audit Event</h2>
      <% if @latest_audit_log %>
        <p class="mt-4 text-sm font-medium text-white"><%= @latest_audit_log.summary %></p>
        <p class="mt-2 text-sm text-zinc-400"><%= @latest_audit_log.admin_email %> · <%= l(@latest_audit_log.created_at, format: :long) %></p>
        <p class="mt-2 text-sm text-zinc-500"><%= @latest_audit_log.details.presence || "No additional details" %></p>
      <% else %>
        <p class="mt-3 text-sm text-zinc-400">No audit events yet.</p>
      <% end %>
    </div>
  </section>
</div>
