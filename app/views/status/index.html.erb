<% content_for :title, "Plex Status" %>

<div class="mx-auto flex w-full max-w-[100rem] flex-col gap-6 px-4 py-6 sm:px-6 lg:px-8">
  <header class="flex min-h-16 flex-col gap-4 border-b border-zinc-800 pb-5 sm:flex-row sm:items-center sm:justify-between">
    <div class="flex min-w-0 flex-wrap items-baseline gap-x-3 gap-y-1">
      <h1 class="text-3xl font-semibold tracking-normal text-white">Status</h1>
    </div>
    <%= render "shared/page_nav" %>
  </header>

  <section class="grid gap-3 sm:grid-cols-2 xl:grid-cols-4">
    <div class="rounded-lg border border-zinc-800 bg-zinc-950 p-4">
      <p class="text-xs font-medium uppercase tracking-wide text-zinc-500">Revision</p>
      <p class="mt-2 text-lg font-semibold text-white"><%= @app_revision %></p>
    </div>
    <div class="rounded-lg border border-zinc-800 bg-zinc-950 p-4">
      <p class="text-xs font-medium uppercase tracking-wide text-zinc-500">Database</p>
      <p class="mt-2 text-lg font-semibold text-white"><%= @database_ok ? "Connected" : "Unavailable" %></p>
    </div>
    <div class="rounded-lg border border-zinc-800 bg-zinc-950 p-4">
      <p class="text-xs font-medium uppercase tracking-wide text-zinc-500">Latest Snapshot</p>
      <p class="mt-2 text-lg font-semibold text-white"><%= @latest_snapshot ? l(@latest_snapshot.fetched_at, format: :short) : "None" %></p>
    </div>
    <div class="rounded-lg border border-zinc-800 bg-zinc-950 p-4">
      <p class="text-xs font-medium uppercase tracking-wide text-zinc-500">Active Refresh</p>
      <p class="mt-2 text-lg font-semibold text-white"><%= @active_refresh_run&.label || "None" %></p>
    </div>
    <div class="rounded-lg border border-zinc-800 bg-zinc-950 p-4">
      <p class="text-xs font-medium uppercase tracking-wide text-zinc-500">Last Completed</p>
      <p class="mt-2 text-lg font-semibold text-white"><%= @last_completed_refresh&.finished_at ? l(@last_completed_refresh.finished_at, format: :short) : "None" %></p>
    </div>
    <div class="rounded-lg border border-zinc-800 bg-zinc-950 p-4">
      <p class="text-xs font-medium uppercase tracking-wide text-zinc-500">Next Scheduled</p>
      <p class="mt-2 text-lg font-semibold text-white"><%= @next_daily_refresh_at ? l(@next_daily_refresh_at, format: :short) : "Unknown" %></p>
    </div>
    <div class="rounded-lg border border-zinc-800 bg-zinc-950 p-4">
      <p class="text-xs font-medium uppercase tracking-wide text-zinc-500">Latest Run</p>
      <p class="mt-2 text-lg font-semibold text-white"><%= @latest_refresh&.label || "None" %></p>
    </div>
    <div class="rounded-lg border border-zinc-800 bg-zinc-950 p-4">
      <p class="text-xs font-medium uppercase tracking-wide text-zinc-500">History Rows</p>
      <p class="mt-2 text-lg font-semibold text-white"><%= @history_summary ? number_with_delimiter(@history_summary[:total]) : "Unknown" %></p>
    </div>
    <div class="rounded-lg border border-zinc-800 bg-zinc-950 p-4">
      <p class="text-xs font-medium uppercase tracking-wide text-zinc-500">Last Backfill</p>
      <p class="mt-2 text-lg font-semibold text-white"><%= @last_backfill_refresh&.finished_at ? l(@last_backfill_refresh.finished_at, format: :short) : "Unknown" %></p>
    </div>
    <div class="rounded-lg border border-zinc-800 bg-zinc-950 p-4">
      <p class="text-xs font-medium uppercase tracking-wide text-zinc-500">Now Samples</p>
      <p class="mt-2 text-lg font-semibold text-white"><%= number_with_delimiter(@now_playing_sample_count) %></p>
    </div>
  </section>

  <section class="grid gap-4 lg:grid-cols-2">
    <div class="rounded-lg border border-zinc-800 bg-zinc-950 p-5">
      <h2 class="text-lg font-semibold text-white">Last Audit Event</h2>
      <% if @latest_audit_log %>
        <p class="mt-4 text-sm font-medium text-white"><%= @latest_audit_log.summary %></p>
        <p class="mt-2 text-sm text-zinc-400"><%= @latest_audit_log.admin_email %> · <%= l(@latest_audit_log.created_at, format: :long) %></p>
        <p class="mt-2 text-sm text-zinc-500"><%= @latest_audit_log.details.presence || "No additional details" %></p>
      <% else %>
        <p class="mt-3 text-sm text-zinc-400">No audit events yet.</p>
      <% end %>
    </div>

    <div class="rounded-lg border border-zinc-800 bg-zinc-950 p-5">
      <h2 class="text-lg font-semibold text-white">Playback History</h2>
      <% if @history_summary && @history_summary[:total].positive? %>
        <dl class="mt-4 grid gap-2 text-sm text-zinc-400">
          <div><dt class="inline text-zinc-500">Events:</dt> <dd class="inline"><%= number_with_delimiter(@history_summary[:total]) %></dd></div>
          <div><dt class="inline text-zinc-500">Completed plays:</dt> <dd class="inline"><%= number_with_delimiter(@history_summary[:completed_plays]) %></dd></div>
          <div><dt class="inline text-zinc-500">Oldest:</dt> <dd class="inline"><%= l(@history_summary[:oldest], format: :long) %></dd></div>
          <div><dt class="inline text-zinc-500">Newest:</dt> <dd class="inline"><%= l(@history_summary[:newest], format: :long) %></dd></div>
          <div><dt class="inline text-zinc-500">With player:</dt> <dd class="inline"><%= number_with_delimiter(@history_summary[:with_player]) %></dd></div>
          <div><dt class="inline text-zinc-500">With IP:</dt> <dd class="inline"><%= number_with_delimiter(@history_summary[:with_ip]) %></dd></div>
        </dl>
      <% else %>
        <p class="mt-3 text-sm text-zinc-400">No local playback history has been stored yet.</p>
      <% end %>
    </div>

    <div class="rounded-lg border border-zinc-800 bg-zinc-950 p-5">
      <h2 class="text-lg font-semibold text-white">Now Playing Samples</h2>
      <% if @latest_now_playing_sample %>
        <dl class="mt-4 grid gap-2 text-sm text-zinc-400">
          <div><dt class="inline text-zinc-500">Samples:</dt> <dd class="inline"><%= number_with_delimiter(@now_playing_sample_count) %></dd></div>
          <div><dt class="inline text-zinc-500">Latest:</dt> <dd class="inline"><%= l(@latest_now_playing_sample.sampled_at, format: :long) %></dd></div>
          <div><dt class="inline text-zinc-500">Latest user:</dt> <dd class="inline"><%= @latest_now_playing_sample.user_label.presence || "Unknown" %></dd></div>
          <div><dt class="inline text-zinc-500">Latest player:</dt> <dd class="inline"><%= [ @latest_now_playing_sample.player_title, @latest_now_playing_sample.player_platform ].compact_blank.join(" · ").presence || "Unknown" %></dd></div>
        </dl>
      <% else %>
        <p class="mt-3 text-sm text-zinc-400">No live playback samples have been stored yet.</p>
      <% end %>
    </div>
  </section>
</div>
