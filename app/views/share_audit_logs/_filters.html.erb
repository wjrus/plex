<%= form_with url: share_audit_logs_path, method: :get, class: "grid gap-3 lg:grid-cols-[minmax(14rem,1fr)_repeat(4,minmax(10rem,12rem))_auto]" do %>
  <div>
    <label for="q" class="text-xs font-semibold uppercase tracking-wide text-zinc-500">User</label>
    <%= search_field_tag :q,
      @filter_params[:q],
      id: "q",
      placeholder: "Name, email, or ID",
      class: "mt-2 w-full rounded-md border border-zinc-700 bg-zinc-900 px-3 py-2 text-sm text-zinc-100 focus:border-cyan-300 focus:outline-none focus:ring-2 focus:ring-cyan-300/30" %>
  </div>
  <div>
    <label for="admin_email" class="text-xs font-semibold uppercase tracking-wide text-zinc-500">Admin</label>
    <%= select_tag :admin_email,
      options_for_select([ [ "Any", "" ] ] + @admins.map { |admin| [ admin, admin ] }, @filter_params[:admin_email]),
      id: "admin_email",
      class: "mt-2 w-full rounded-md border border-zinc-700 bg-zinc-900 px-3 py-2 text-sm text-zinc-100 focus:border-cyan-300 focus:outline-none focus:ring-2 focus:ring-cyan-300/30" %>
  </div>
  <div>
    <label for="action_type" class="text-xs font-semibold uppercase tracking-wide text-zinc-500">Action</label>
    <%= select_tag :action_type,
      options_for_select([ [ "Any", "" ] ] + @actions.map { |action| [ action.humanize, action ] }, @filter_params[:action_type]),
      id: "action_type",
      class: "mt-2 w-full rounded-md border border-zinc-700 bg-zinc-900 px-3 py-2 text-sm text-zinc-100 focus:border-cyan-300 focus:outline-none focus:ring-2 focus:ring-cyan-300/30" %>
  </div>
  <div>
    <label for="from" class="text-xs font-semibold uppercase tracking-wide text-zinc-500">From</label>
    <%= date_field_tag :from,
      @filter_params[:from],
      id: "from",
      class: "mt-2 w-full rounded-md border border-zinc-700 bg-zinc-900 px-3 py-2 text-sm text-zinc-100 focus:border-cyan-300 focus:outline-none focus:ring-2 focus:ring-cyan-300/30" %>
  </div>
  <div>
    <label for="to" class="text-xs font-semibold uppercase tracking-wide text-zinc-500">To</label>
    <%= date_field_tag :to,
      @filter_params[:to],
      id: "to",
      class: "mt-2 w-full rounded-md border border-zinc-700 bg-zinc-900 px-3 py-2 text-sm text-zinc-100 focus:border-cyan-300 focus:outline-none focus:ring-2 focus:ring-cyan-300/30" %>
  </div>
  <div class="flex items-end gap-2">
    <button type="submit" class="inline-flex items-center justify-center rounded-md bg-cyan-300 px-4 py-2 text-sm font-semibold text-zinc-950 transition hover:bg-cyan-200 focus:outline-none focus:ring-2 focus:ring-cyan-200 focus:ring-offset-2 focus:ring-offset-zinc-950">Filter</button>
    <%= link_to "CSV", share_audit_logs_path(request.query_parameters.merge(format: :csv)), class: "inline-flex items-center justify-center rounded-md border border-zinc-700 px-4 py-2 text-sm font-semibold text-zinc-200 transition hover:border-zinc-500 hover:bg-zinc-900 focus:outline-none focus:ring-2 focus:ring-zinc-500 focus:ring-offset-2 focus:ring-offset-zinc-950" %>
    <%= link_to "Clear", share_audit_logs_path, class: "inline-flex items-center justify-center rounded-md border border-zinc-700 px-4 py-2 text-sm font-semibold text-zinc-200 transition hover:border-zinc-500 hover:bg-zinc-900 focus:outline-none focus:ring-2 focus:ring-zinc-500 focus:ring-offset-2 focus:ring-offset-zinc-950" %>
  </div>
<% end %>
<p class="mt-3 text-xs text-zinc-500"><%= pluralize(@audit_logs.size, "entry") %> shown</p>
