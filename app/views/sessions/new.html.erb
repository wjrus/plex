<% content_for :title, "Sign In" %>

<div class="flex min-h-screen items-center justify-center px-4 py-10">
  <section class="w-full max-w-md rounded-lg border border-zinc-800 bg-zinc-900 p-6 shadow-2xl shadow-black/30">
    <h1 class="text-2xl font-semibold text-white">Sign in</h1>
    <p class="mt-2 text-sm leading-6 text-zinc-400">Use the configured Google account to view Plex library sharing.</p>

    <% if ENV["GOOGLE_CLIENT_ID"].blank? || ENV["GOOGLE_CLIENT_SECRET"].blank? %>
      <div class="mt-5 rounded-lg border border-amber-500/40 bg-amber-950/40 p-4 text-sm leading-6 text-amber-50/80">
        Add <code class="rounded bg-black/30 px-1.5 py-0.5">GOOGLE_CLIENT_ID</code> and
        <code class="rounded bg-black/30 px-1.5 py-0.5">GOOGLE_CLIENT_SECRET</code> to
        <code class="rounded bg-black/30 px-1.5 py-0.5">.env</code>.
      </div>
    <% else %>
      <%= button_to "/auth/google_oauth2", method: :post, data: { turbo: false }, class: "mt-6 inline-flex w-full items-center justify-center rounded-md bg-cyan-300 px-4 py-2.5 text-sm font-semibold text-zinc-950 transition hover:bg-cyan-200 focus:outline-none focus:ring-2 focus:ring-cyan-200 focus:ring-offset-2 focus:ring-offset-zinc-900" do %>
        Continue with Google
      <% end %>
    <% end %>
  </section>
</div>
