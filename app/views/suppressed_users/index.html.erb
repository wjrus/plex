<% content_for :title, "Suppressed Plex Users" %>

<div class="mx-auto flex w-full max-w-[100rem] flex-col gap-6 px-4 py-6 sm:px-6 lg:px-8">
  <header class="flex min-h-16 flex-col gap-4 border-b border-zinc-800 pb-5 sm:flex-row sm:items-center sm:justify-between">
    <div class="flex min-w-0 flex-wrap items-baseline gap-x-3 gap-y-1">
      <h1 class="text-3xl font-semibold tracking-normal text-white">Suppressed Users</h1>
      <span class="text-sm text-zinc-400"><%= pluralize(@suppressed_notes.size, "hidden account") %></span>
    </div>
    <%= render "shared/page_nav" %>
  </header>

  <% if @suppressed_notes.empty? %>
    <section class="rounded-lg border border-zinc-800 bg-zinc-950 p-5">
      <p class="text-sm text-zinc-400">No users are suppressed.</p>
    </section>
  <% else %>
    <section class="overflow-hidden rounded-lg border border-zinc-800 bg-zinc-950">
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-zinc-800 text-left text-sm">
          <thead class="bg-zinc-900/80 text-xs uppercase tracking-wide text-zinc-400">
            <tr>
              <th class="px-4 py-3 font-semibold">User</th>
              <th class="px-4 py-3 font-semibold">Notes</th>
              <th class="px-4 py-3 font-semibold">Last Stream</th>
              <th class="px-4 py-3 font-semibold">Suppressed</th>
              <th class="px-4 py-3 font-semibold">Action</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-zinc-800">
            <% @suppressed_notes.each do |note| %>
              <% stream = @latest_streams_by_user_id[note.plex_user_id] %>
              <tr>
                <td class="px-4 py-3">
                  <div class="font-medium text-white"><%= note.username.presence || note.email.presence || "Account #{note.plex_user_id}" %></div>
                  <div class="mt-1 text-xs text-zinc-500"><%= note.email.presence || "No email" %> · ID <%= note.plex_user_id %></div>
                </td>
                <td class="max-w-md px-4 py-3 text-zinc-300">
                  <% if note.notes.present? %>
                    <p class="whitespace-pre-wrap leading-5"><%= note.notes %></p>
                  <% else %>
                    <span class="text-zinc-500">No notes</span>
                  <% end %>
                </td>
                <td class="px-4 py-3 text-zinc-300">
                  <% if stream %>
                    <div><%= l(stream.viewed_at, format: :long) %></div>
                    <div class="mt-1 text-xs text-zinc-500"><%= stream.label %></div>
                  <% else %>
                    <span class="text-zinc-500">Unknown</span>
                  <% end %>
                </td>
                <td class="px-4 py-3 text-zinc-300">
                  <div><%= note.suppressed_at ? l(note.suppressed_at, format: :long) : "Unknown" %></div>
                  <div class="mt-1 text-xs text-zinc-500"><%= note.suppressed_by.presence || "unknown admin" %></div>
                </td>
                <td class="px-4 py-3">
                  <div class="flex flex-wrap gap-2">
                    <%= link_to "Open",
                      user_path(note.plex_user_id),
                      class: "inline-flex items-center justify-center rounded-md border border-zinc-700 px-3 py-1.5 text-xs font-semibold text-zinc-200 transition hover:border-zinc-500 hover:bg-zinc-900 hover:text-white focus:outline-none focus:ring-2 focus:ring-zinc-500 focus:ring-offset-2 focus:ring-offset-zinc-950" %>
                    <%= button_to "Unsuppress",
                      user_suppression_path(note.plex_user_id),
                      method: :patch,
                      params: { suppressed: "0", return_to: suppressed_users_path },
                      class: "inline-flex items-center justify-center rounded-md bg-cyan-300 px-3 py-1.5 text-xs font-semibold text-zinc-950 transition hover:bg-cyan-200 focus:outline-none focus:ring-2 focus:ring-cyan-200 focus:ring-offset-2 focus:ring-offset-zinc-950" %>
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </section>
  <% end %>
</div>
