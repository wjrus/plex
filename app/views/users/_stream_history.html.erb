<%= turbo_frame_tag "stream_history" do %>
  <section class="overflow-hidden rounded-lg border border-zinc-800 bg-zinc-950">
    <div class="grid gap-4 border-b border-zinc-800 p-5">
      <div class="flex flex-col gap-2 sm:flex-row sm:items-center sm:justify-between">
        <div>
        <h2 class="text-lg font-semibold text-white">Stream History</h2>
        <% if @stream_events_count.positive? %>
          <p class="mt-1 text-xs text-zinc-500">
            Showing <%= @stream_page_start %>-<%= @stream_page_end %> of <%= number_with_delimiter(@stream_events_count) %>
            · <%= link_to "Export CSV", user_path(@user.id, stream_query_params(format: :csv)), class: "font-semibold text-cyan-300 hover:text-white", data: { turbo: false } %>
          </p>
        <% end %>
      </div>
      <% if @stream_total_pages > 1 %>
        <nav class="flex items-center gap-2 text-sm" aria-label="Stream history pages">
          <% previous_page = @stream_page - 1 %>
          <% next_page = @stream_page + 1 %>
          <% if @stream_page > 1 %>
            <%= link_to "Previous",
              user_path(@user.id, stream_query_params(stream_page: previous_page)),
              data: { turbo_frame: "stream_history" },
              class: "inline-flex cursor-pointer items-center justify-center rounded-md border border-zinc-700 px-3 py-1.5 font-semibold text-zinc-200 transition hover:border-zinc-500 hover:bg-zinc-900 hover:text-white focus:outline-none focus:ring-2 focus:ring-zinc-500 focus:ring-offset-2 focus:ring-offset-zinc-950" %>
          <% else %>
            <span class="inline-flex items-center justify-center rounded-md border border-zinc-800 px-3 py-1.5 font-semibold text-zinc-600">Previous</span>
          <% end %>
          <span class="px-1 text-xs text-zinc-500">Page <%= @stream_page %> of <%= @stream_total_pages %></span>
          <% if @stream_page < @stream_total_pages %>
            <%= link_to "Next",
              user_path(@user.id, stream_query_params(stream_page: next_page)),
              data: { turbo_frame: "stream_history" },
              class: "inline-flex cursor-pointer items-center justify-center rounded-md border border-zinc-700 px-3 py-1.5 font-semibold text-zinc-200 transition hover:border-zinc-500 hover:bg-zinc-900 hover:text-white focus:outline-none focus:ring-2 focus:ring-zinc-500 focus:ring-offset-2 focus:ring-offset-zinc-950" %>
          <% else %>
            <span class="inline-flex items-center justify-center rounded-md border border-zinc-800 px-3 py-1.5 font-semibold text-zinc-600">Next</span>
          <% end %>
        </nav>
      <% end %>
      </div>

      <%= form_with url: user_path(@user.id), method: :get, data: { turbo_frame: "stream_history" }, class: "grid gap-3 lg:grid-cols-[minmax(14rem,1fr)_repeat(3,minmax(9rem,11rem))_auto]" do %>
        <div>
          <label for="stream_q" class="text-xs font-semibold uppercase tracking-wide text-zinc-500">Search</label>
          <%= search_field_tag :stream_q,
            @stream_filter_params[:stream_q],
            id: "stream_q",
            placeholder: "Title, library, rating key",
            class: "mt-2 w-full rounded-md border border-zinc-700 bg-zinc-900 px-3 py-2 text-sm text-zinc-100 focus:border-cyan-300 focus:outline-none focus:ring-2 focus:ring-cyan-300/30" %>
        </div>
        <div>
          <label for="stream_type" class="text-xs font-semibold uppercase tracking-wide text-zinc-500">Type</label>
          <%= select_tag :stream_type,
            options_for_select([ [ "Any", "" ] ] + @stream_type_options.map { |type| [ type, type ] }, @stream_filter_params[:stream_type]),
            id: "stream_type",
            class: "mt-2 w-full rounded-md border border-zinc-700 bg-zinc-900 px-3 py-2 text-sm text-zinc-100 focus:border-cyan-300 focus:outline-none focus:ring-2 focus:ring-cyan-300/30" %>
        </div>
        <div>
          <label for="stream_from" class="text-xs font-semibold uppercase tracking-wide text-zinc-500">From</label>
          <%= date_field_tag :stream_from,
            @stream_filter_params[:stream_from],
            id: "stream_from",
            class: "mt-2 w-full rounded-md border border-zinc-700 bg-zinc-900 px-3 py-2 text-sm text-zinc-100 focus:border-cyan-300 focus:outline-none focus:ring-2 focus:ring-cyan-300/30" %>
        </div>
        <div>
          <label for="stream_to" class="text-xs font-semibold uppercase tracking-wide text-zinc-500">To</label>
          <%= date_field_tag :stream_to,
            @stream_filter_params[:stream_to],
            id: "stream_to",
            class: "mt-2 w-full rounded-md border border-zinc-700 bg-zinc-900 px-3 py-2 text-sm text-zinc-100 focus:border-cyan-300 focus:outline-none focus:ring-2 focus:ring-cyan-300/30" %>
        </div>
        <div class="flex items-end gap-2">
          <button type="submit" class="inline-flex items-center justify-center rounded-md bg-cyan-300 px-4 py-2 text-sm font-semibold text-zinc-950 transition hover:bg-cyan-200 focus:outline-none focus:ring-2 focus:ring-cyan-200 focus:ring-offset-2 focus:ring-offset-zinc-950">Filter</button>
          <% if @stream_filters_active %>
            <%= link_to "Clear",
              user_path(@user.id),
              data: { turbo_frame: "stream_history" },
              class: "inline-flex items-center justify-center rounded-md border border-zinc-700 px-4 py-2 text-sm font-semibold text-zinc-200 transition hover:border-zinc-500 hover:bg-zinc-900 hover:text-white focus:outline-none focus:ring-2 focus:ring-zinc-500 focus:ring-offset-2 focus:ring-offset-zinc-950" %>
          <% end %>
        </div>
      <% end %>
    </div>

    <% if @stream_events.empty? %>
      <p class="p-5 text-sm text-zinc-400"><%= @stream_filters_active ? "No stream history matches those filters." : "No local stream history for this user yet. Run a refresh with playback history to populate it." %></p>
    <% else %>
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-zinc-800 text-left text-sm">
          <thead class="bg-zinc-900/80 text-xs uppercase tracking-wide text-zinc-400">
            <tr>
              <th class="px-4 py-3 font-semibold">When</th>
              <th class="px-4 py-3 font-semibold">Cover</th>
              <th class="px-4 py-3 font-semibold">Title</th>
              <th class="px-4 py-3 font-semibold">Type</th>
              <% if @stream_has_player_data %>
                <th class="px-4 py-3 font-semibold">Player</th>
              <% end %>
              <% if @stream_has_ip_data %>
                <th class="px-4 py-3 font-semibold">IP Address</th>
              <% end %>
            </tr>
          </thead>
          <tbody class="divide-y divide-zinc-800">
            <% @stream_events.each do |event| %>
              <% cover_url = plex_image_url(event.cover_path) %>
              <tr>
                <td class="whitespace-nowrap px-4 py-3 text-zinc-300"><%= l(event.viewed_at, format: :long) %></td>
                <td class="px-4 py-3">
                  <div class="h-16 w-11 overflow-hidden rounded border border-zinc-800 bg-zinc-900">
                    <% if cover_url.present? %>
                      <img src="<%= cover_url %>" alt="" class="h-full w-full object-cover">
                    <% end %>
                  </div>
                </td>
                <td class="px-4 py-3 font-medium text-white"><%= event.label %></td>
                <td class="px-4 py-3 text-zinc-400"><%= event.media_type.presence || "unknown" %></td>
                <% if @stream_has_player_data %>
                  <td class="px-4 py-3 text-zinc-300"><%= event.player_label %></td>
                <% end %>
                <% if @stream_has_ip_data %>
                  <td class="px-4 py-3 text-zinc-400"><%= event.ip_address.presence || "Unknown" %></td>
                <% end %>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% end %>
  </section>
<% end %>
