<% content_for :title, "Plex Users" %>

<div class="mx-auto flex w-full max-w-[100rem] flex-col gap-6 px-4 py-6 sm:px-6 lg:px-8">
  <header class="flex min-h-16 flex-col gap-4 border-b border-zinc-800 pb-5 sm:flex-row sm:items-center sm:justify-between">
    <div class="flex min-w-0 flex-wrap items-baseline gap-x-3 gap-y-1">
      <h1 class="text-3xl font-semibold tracking-normal text-white">Users</h1>
    </div>
    <%= render "shared/page_nav" %>
  </header>

  <% if @configuration_error.present? || @plex_error.present? %>
    <section class="rounded-lg border border-amber-500/40 bg-amber-950/40 p-5">
      <h2 class="text-lg font-semibold text-amber-100">Unavailable</h2>
      <p class="mt-2 text-sm leading-6 text-amber-50/80"><%= @configuration_error || @plex_error %></p>
    </section>
  <% elsif @snapshot.blank? %>
    <section class="rounded-lg border border-zinc-800 bg-zinc-900 p-5">
      <p class="text-sm leading-6 text-zinc-400">No local snapshot yet. Refresh Plex shares from the main page first.</p>
    </section>
  <% end %>

  <% if @snapshot.present? %>
    <% if @pending_users.any? %>
      <section class="rounded-lg border border-amber-400/30 bg-amber-400/10 p-5">
        <div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between">
          <div>
            <h2 class="text-lg font-semibold text-white">Pending Invites</h2>
            <p class="mt-1 text-sm text-zinc-400"><%= pluralize(@pending_users.size, "invite") %> awaiting acceptance.</p>
            <p class="mt-2 text-sm text-zinc-300"><%= @pending_users.map(&:label).to_sentence %></p>
          </div>
          <%= link_to "View pending",
            users_path(status: "pending"),
            class: "inline-flex shrink-0 items-center justify-center rounded-md border border-zinc-700 px-4 py-2 text-sm font-semibold text-zinc-200 transition hover:border-zinc-500 hover:bg-zinc-900 focus:outline-none focus:ring-2 focus:ring-zinc-500 focus:ring-offset-2 focus:ring-offset-zinc-950" %>
        </div>
      </section>
      <% end %>

    <% if @suppressed_user_count.positive? && @filter_params[:status] != "suppressed" %>
      <section class="rounded-lg border border-zinc-800 bg-zinc-950 p-5">
        <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
          <p class="text-sm text-zinc-400">
            <%= pluralize(@suppressed_user_count, "suppressed user") %> hidden from default lists.
          </p>
          <%= link_to "View suppressed",
            suppressed_users_path,
            class: "inline-flex shrink-0 items-center justify-center rounded-md border border-zinc-700 px-4 py-2 text-sm font-semibold text-zinc-200 transition hover:border-zinc-500 hover:bg-zinc-900 focus:outline-none focus:ring-2 focus:ring-zinc-500 focus:ring-offset-2 focus:ring-offset-zinc-950" %>
        </div>
      </section>
    <% end %>

    <section class="rounded-lg border border-zinc-800 bg-zinc-950 p-5">
      <%= form_with url: users_path, method: :get, class: "grid gap-3 lg:grid-cols-[minmax(14rem,1fr)_repeat(4,minmax(10rem,12rem))_auto]" do %>
        <div>
          <label for="q" class="text-xs font-semibold uppercase tracking-wide text-zinc-500">Search</label>
          <%= search_field_tag :q,
            @filter_params[:q],
            id: "q",
            placeholder: "Name or email",
            class: "mt-2 w-full rounded-md border border-zinc-700 bg-zinc-900 px-3 py-2 text-sm text-zinc-100 focus:border-cyan-300 focus:outline-none focus:ring-2 focus:ring-cyan-300/30" %>
        </div>
        <div>
          <label for="status" class="text-xs font-semibold uppercase tracking-wide text-zinc-500">Invitation</label>
          <%= select_tag :status,
            options_for_select([ [ "Any", "" ], [ "Accepted", "accepted" ], [ "Pending", "pending" ], [ "Suppressed", "suppressed" ] ], @filter_params[:status]),
            id: "status",
            class: "mt-2 w-full rounded-md border border-zinc-700 bg-zinc-900 px-3 py-2 text-sm text-zinc-100 focus:border-cyan-300 focus:outline-none focus:ring-2 focus:ring-cyan-300/30" %>
        </div>
        <div>
          <label for="library_id" class="text-xs font-semibold uppercase tracking-wide text-zinc-500">Library</label>
          <%= select_tag :library_id,
            options_for_select([ [ "Any", "" ] ] + @libraries.map { |library| [ library.title, library.id ] }, @filter_params[:library_id]),
            id: "library_id",
            class: "mt-2 w-full rounded-md border border-zinc-700 bg-zinc-900 px-3 py-2 text-sm text-zinc-100 focus:border-cyan-300 focus:outline-none focus:ring-2 focus:ring-cyan-300/30" %>
        </div>
        <div>
          <label for="notes" class="text-xs font-semibold uppercase tracking-wide text-zinc-500">Notes</label>
          <%= select_tag :notes,
            options_for_select([ [ "Any", "" ], [ "Has notes", "with" ], [ "No notes", "without" ] ], @filter_params[:notes]),
            id: "notes",
            class: "mt-2 w-full rounded-md border border-zinc-700 bg-zinc-900 px-3 py-2 text-sm text-zinc-100 focus:border-cyan-300 focus:outline-none focus:ring-2 focus:ring-cyan-300/30" %>
        </div>
        <div>
          <label for="streaming" class="text-xs font-semibold uppercase tracking-wide text-zinc-500">Streaming</label>
          <%= select_tag :streaming,
            options_for_select([ [ "Any", "" ], [ "Has streamed", "streamed" ], [ "Never/unknown", "never" ] ], @filter_params[:streaming]),
            id: "streaming",
            class: "mt-2 w-full rounded-md border border-zinc-700 bg-zinc-900 px-3 py-2 text-sm text-zinc-100 focus:border-cyan-300 focus:outline-none focus:ring-2 focus:ring-cyan-300/30" %>
        </div>
        <div class="flex items-end gap-2">
          <button type="submit" class="inline-flex items-center justify-center rounded-md bg-cyan-300 px-4 py-2 text-sm font-semibold text-zinc-950 transition hover:bg-cyan-200 focus:outline-none focus:ring-2 focus:ring-cyan-200 focus:ring-offset-2 focus:ring-offset-zinc-950">Filter</button>
          <%= link_to "CSV", users_path(request.query_parameters.merge(format: :csv)), class: "inline-flex items-center justify-center rounded-md border border-zinc-700 px-4 py-2 text-sm font-semibold text-zinc-200 transition hover:border-zinc-500 hover:bg-zinc-900 focus:outline-none focus:ring-2 focus:ring-zinc-500 focus:ring-offset-2 focus:ring-offset-zinc-950" %>
          <%= link_to "Clear", users_path, class: "inline-flex items-center justify-center rounded-md border border-zinc-700 px-4 py-2 text-sm font-semibold text-zinc-200 transition hover:border-zinc-500 hover:bg-zinc-900 focus:outline-none focus:ring-2 focus:ring-zinc-500 focus:ring-offset-2 focus:ring-offset-zinc-950" %>
        </div>
        <%= hidden_field_tag :sort, @sort %>
        <%= hidden_field_tag :direction, @direction %>
      <% end %>
      <p class="mt-3 text-xs text-zinc-500"><%= pluralize(@users.size, "user") %> shown</p>
    </section>
  <% end %>

  <% if @snapshot.present? && @users.empty? %>
    <section class="rounded-lg border border-zinc-800 bg-zinc-900 p-5">
      <p class="text-sm leading-6 text-zinc-400">No users match those filters.</p>
    </section>
  <% elsif @users.any? %>
    <section class="overflow-hidden rounded-lg border border-zinc-800 bg-zinc-950">
      <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-zinc-800 text-left text-sm">
        <thead class="bg-zinc-900/80 text-xs uppercase tracking-wide text-zinc-400">
          <tr>
            <th class="px-4 py-3 font-semibold"><%= users_sort_link("Name", "name") %></th>
            <th class="px-4 py-3 font-semibold">Email</th>
            <th class="px-4 py-3 font-semibold">Invitation</th>
            <th class="px-4 py-3 font-semibold">Activity</th>
            <th class="px-4 py-3 font-semibold"><%= users_sort_link("Last Streamed", "last_streamed") %></th>
            <th class="px-4 py-3 font-semibold">Shared Libraries</th>
            <th class="px-4 py-3 font-semibold">Notes</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-zinc-800">
          <% @users.each do |user| %>
            <% note = @notes_by_user_id[user.id.to_s] %>
            <% audit_count = @audit_counts_by_user_id.fetch(user.id.to_s, 0) %>
            <tr class="user-row-link"
              data-controller="row-link"
              data-row-link-url-value="<%= user_path(user.id) %>"
              data-action="click->row-link#open keydown->row-link#openWithKeyboard"
              tabindex="0"
              role="link"
              aria-label="Open <%= user.label %>">
              <td class="px-4 py-3 font-medium text-white"><%= user.title.presence || user.label %></td>
              <td class="px-4 py-3 text-zinc-300"><%= user.email.presence || "unknown" %></td>
              <td class="px-4 py-3">
                <% if suppressed_user?(user) %>
                  <span class="inline-flex rounded-md border border-zinc-500/40 bg-zinc-500/10 px-2 py-1 text-xs font-semibold text-zinc-200">Suppressed</span>
                <% elsif user.pending %>
                  <span class="inline-flex rounded-md border border-amber-400/30 bg-amber-400/10 px-2 py-1 text-xs font-semibold text-amber-200">Pending</span>
                <% elsif local_history_user?(user) %>
                  <span class="inline-flex rounded-md border border-cyan-300/30 bg-cyan-300/10 px-2 py-1 text-xs font-semibold text-cyan-100">Local history</span>
                <% else %>
                  <span class="inline-flex rounded-md border border-emerald-400/30 bg-emerald-400/10 px-2 py-1 text-xs font-semibold text-emerald-200">Accepted</span>
                <% end %>
              </td>
              <td class="min-w-60 px-4 py-3 text-zinc-300">
                <p class="text-sm"><%= pluralize(user.libraries.size, "library") %> shared</p>
                <p class="mt-1 text-xs text-zinc-500"><%= note&.notes.present? ? "Has notes" : "No notes" %> · <%= pluralize(audit_count, "log event") %></p>
                <% if user.last_streamed_title.present? %>
                  <p class="mt-1 text-xs text-zinc-500"><%= user.last_streamed_title %></p>
                <% end %>
              </td>
              <td class="px-4 py-3 text-zinc-300">
                <div><%= optional_plex_timestamp(user.last_streamed_at) %></div>
                <% if user.last_streamed_title.present? %>
                  <div class="mt-1 text-xs text-zinc-500"><%= user.last_streamed_title %></div>
                <% end %>
              </td>
              <td class="max-w-md px-4 py-3 text-zinc-300">
                <% if user.libraries.any? %>
                  <p class="text-sm"><%= user.libraries.map(&:title).to_sentence %></p>
                  <% if user.all_libraries %>
                    <p class="mt-1 text-xs text-cyan-300">All libraries</p>
                  <% end %>
                <% else %>
                  <p class="text-sm text-zinc-500">
                    <%= user.pending ? pluralize(user.library_count, "pending library") : "No libraries" %>
                  </p>
                <% end %>
              </td>
              <td class="min-w-80 px-4 py-3 text-zinc-300">
                <% if note&.notes.present? %>
                  <p class="whitespace-pre-wrap text-sm leading-5"><%= note.notes %></p>
                <% else %>
                  <p class="text-sm text-zinc-500">No notes</p>
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
      </div>
    </section>
  <% end %>
</div>
