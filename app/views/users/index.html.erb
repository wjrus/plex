<% content_for :title, "Plex Users" %>

<div class="mx-auto flex w-full max-w-[100rem] flex-col gap-6 px-4 py-6 sm:px-6 lg:px-8">
  <header class="flex flex-col gap-4 border-b border-zinc-800 pb-5 sm:flex-row sm:items-end sm:justify-between">
    <div>
      <p class="text-sm font-medium uppercase tracking-wide text-cyan-300">Plex directory</p>
      <h1 class="mt-2 text-3xl font-semibold tracking-normal text-white">Users</h1>
    </div>
    <div class="flex flex-wrap gap-2">
      <%= link_to "Log", share_audit_logs_path, class: "inline-flex items-center justify-center rounded-md border border-zinc-700 px-4 py-2 text-sm font-semibold text-zinc-200 transition hover:border-zinc-500 hover:bg-zinc-900 focus:outline-none focus:ring-2 focus:ring-zinc-500 focus:ring-offset-2 focus:ring-offset-zinc-950" %>
      <%= link_to "Shares", root_path, class: "inline-flex items-center justify-center rounded-md border border-zinc-700 px-4 py-2 text-sm font-semibold text-zinc-200 transition hover:border-zinc-500 hover:bg-zinc-900 focus:outline-none focus:ring-2 focus:ring-zinc-500 focus:ring-offset-2 focus:ring-offset-zinc-950" %>
    </div>
  </header>

  <% if @configuration_error.present? || @plex_error.present? %>
    <section class="rounded-lg border border-amber-500/40 bg-amber-950/40 p-5">
      <h2 class="text-lg font-semibold text-amber-100">Unavailable</h2>
      <p class="mt-2 text-sm leading-6 text-amber-50/80"><%= @configuration_error || @plex_error %></p>
    </section>
  <% elsif @users.empty? %>
    <section class="rounded-lg border border-zinc-800 bg-zinc-900 p-5">
      <p class="text-sm leading-6 text-zinc-400">No local snapshot yet. Refresh Plex shares from the main page first.</p>
    </section>
  <% else %>
    <section class="overflow-hidden rounded-lg border border-zinc-800 bg-zinc-950">
      <table class="min-w-full divide-y divide-zinc-800 text-left text-sm">
        <thead class="bg-zinc-900/80 text-xs uppercase tracking-wide text-zinc-400">
          <tr>
            <th class="px-4 py-3 font-semibold"><%= users_sort_link("Name", "name") %></th>
            <th class="px-4 py-3 font-semibold">Email</th>
            <th class="px-4 py-3 font-semibold">Invitation</th>
            <th class="px-4 py-3 font-semibold"><%= users_sort_link("Last Streamed", "last_streamed") %></th>
            <th class="px-4 py-3 font-semibold">Shared Libraries</th>
            <th class="px-4 py-3 font-semibold">Notes</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-zinc-800">
          <% @users.each do |user| %>
            <% note = @notes_by_user_id[user.id.to_s] %>
            <tr>
              <td class="px-4 py-3 font-medium text-white"><%= link_to user.title.presence || user.label, user_path(user.id), class: "hover:text-cyan-300" %></td>
              <td class="px-4 py-3 text-zinc-300"><%= user.email.presence || "unknown" %></td>
              <td class="px-4 py-3">
                <% if user.pending %>
                  <span class="inline-flex rounded-md border border-amber-400/30 bg-amber-400/10 px-2 py-1 text-xs font-semibold text-amber-200">Pending</span>
                <% else %>
                  <span class="inline-flex rounded-md border border-emerald-400/30 bg-emerald-400/10 px-2 py-1 text-xs font-semibold text-emerald-200">Accepted</span>
                <% end %>
              </td>
              <td class="px-4 py-3 text-zinc-300">
                <div><%= optional_plex_timestamp(user.last_streamed_at) %></div>
                <% if user.last_streamed_title.present? %>
                  <div class="mt-1 text-xs text-zinc-500"><%= user.last_streamed_title %></div>
                <% end %>
              </td>
              <td class="max-w-md px-4 py-3 text-zinc-300">
                <% if user.libraries.any? %>
                  <p class="text-sm"><%= user.libraries.map(&:title).to_sentence %></p>
                  <% if user.all_libraries %>
                    <p class="mt-1 text-xs text-cyan-300">All libraries</p>
                  <% end %>
                <% else %>
                  <p class="text-sm text-zinc-500">
                    <%= user.pending ? pluralize(user.library_count, "pending library") : "No libraries" %>
                  </p>
                <% end %>
              </td>
              <td class="min-w-80 px-4 py-3 text-zinc-300">
                <%= form_with scope: :plex_user_note, url: user_note_path(user.id), method: :patch, class: "flex items-start gap-2" do |form| %>
                  <%= hidden_field_tag :sort, @sort %>
                  <%= hidden_field_tag :direction, @direction %>
                  <%= form.hidden_field :username, value: user.username %>
                  <%= form.hidden_field :email, value: user.email %>
                  <%= form.text_area :notes,
                    value: note&.notes,
                    rows: 2,
                    placeholder: "Local admin notes",
                    class: "min-h-16 w-full rounded-md border border-zinc-700 bg-zinc-900 px-3 py-2 text-sm text-zinc-100 focus:border-cyan-300 focus:outline-none focus:ring-2 focus:ring-cyan-300/30" %>
                  <button type="submit" class="inline-flex shrink-0 items-center justify-center rounded-md bg-cyan-300 px-3 py-2 text-xs font-semibold text-zinc-950 transition hover:bg-cyan-200 focus:outline-none focus:ring-2 focus:ring-cyan-200 focus:ring-offset-2 focus:ring-offset-zinc-950">Save</button>
                <% end %>
                <% if note&.updated_at.present? %>
                  <p class="mt-1 text-xs text-zinc-500">
                    Saved <%= time_ago_in_words(note.updated_at) %> ago
                    <% if note.last_edited_by.present? %>
                      by <%= note.last_edited_by %>
                    <% end %>
                  </p>
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </section>
  <% end %>
</div>
