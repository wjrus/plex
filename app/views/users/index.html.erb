<% content_for :title, "Plex Users" %>

<div class="mx-auto flex w-full max-w-[100rem] flex-col gap-6 px-4 py-6 sm:px-6 lg:px-8">
  <header class="flex flex-col gap-4 border-b border-zinc-800 pb-5 sm:flex-row sm:items-end sm:justify-between">
    <div>
      <p class="text-sm font-medium uppercase tracking-wide text-cyan-300">Plex directory</p>
      <h1 class="mt-2 text-3xl font-semibold tracking-normal text-white">Users</h1>
    </div>
    <div class="flex flex-wrap gap-2">
      <%= link_to "Log", share_audit_logs_path, class: "inline-flex items-center justify-center rounded-md border border-zinc-700 px-4 py-2 text-sm font-semibold text-zinc-200 transition hover:border-zinc-500 hover:bg-zinc-900 focus:outline-none focus:ring-2 focus:ring-zinc-500 focus:ring-offset-2 focus:ring-offset-zinc-950" %>
      <%= link_to "Status", status_path, class: "inline-flex items-center justify-center rounded-md border border-zinc-700 px-4 py-2 text-sm font-semibold text-zinc-200 transition hover:border-zinc-500 hover:bg-zinc-900 focus:outline-none focus:ring-2 focus:ring-zinc-500 focus:ring-offset-2 focus:ring-offset-zinc-950" %>
      <%= link_to "Shares", root_path, class: "inline-flex items-center justify-center rounded-md border border-zinc-700 px-4 py-2 text-sm font-semibold text-zinc-200 transition hover:border-zinc-500 hover:bg-zinc-900 focus:outline-none focus:ring-2 focus:ring-zinc-500 focus:ring-offset-2 focus:ring-offset-zinc-950" %>
    </div>
  </header>

  <% if @configuration_error.present? || @plex_error.present? %>
    <section class="rounded-lg border border-amber-500/40 bg-amber-950/40 p-5">
      <h2 class="text-lg font-semibold text-amber-100">Unavailable</h2>
      <p class="mt-2 text-sm leading-6 text-amber-50/80"><%= @configuration_error || @plex_error %></p>
    </section>
  <% elsif @snapshot.blank? %>
    <section class="rounded-lg border border-zinc-800 bg-zinc-900 p-5">
      <p class="text-sm leading-6 text-zinc-400">No local snapshot yet. Refresh Plex shares from the main page first.</p>
    </section>
  <% end %>

  <% if @snapshot.present? %>
    <section class="rounded-lg border border-zinc-800 bg-zinc-950 p-5" data-controller="confirmation">
      <%= form_with url: users_path, method: :get, class: "grid gap-3 lg:grid-cols-[minmax(14rem,1fr)_repeat(4,minmax(10rem,12rem))_auto]" do %>
        <div>
          <label for="q" class="text-xs font-semibold uppercase tracking-wide text-zinc-500">Search</label>
          <%= search_field_tag :q,
            @filter_params[:q],
            id: "q",
            placeholder: "Name or email",
            class: "mt-2 w-full rounded-md border border-zinc-700 bg-zinc-900 px-3 py-2 text-sm text-zinc-100 focus:border-cyan-300 focus:outline-none focus:ring-2 focus:ring-cyan-300/30" %>
        </div>
        <div>
          <label for="status" class="text-xs font-semibold uppercase tracking-wide text-zinc-500">Invitation</label>
          <%= select_tag :status,
            options_for_select([ [ "Any", "" ], [ "Accepted", "accepted" ], [ "Pending", "pending" ] ], @filter_params[:status]),
            id: "status",
            class: "mt-2 w-full rounded-md border border-zinc-700 bg-zinc-900 px-3 py-2 text-sm text-zinc-100 focus:border-cyan-300 focus:outline-none focus:ring-2 focus:ring-cyan-300/30" %>
        </div>
        <div>
          <label for="library_id" class="text-xs font-semibold uppercase tracking-wide text-zinc-500">Library</label>
          <%= select_tag :library_id,
            options_for_select([ [ "Any", "" ] ] + @libraries.map { |library| [ library.title, library.id ] }, @filter_params[:library_id]),
            id: "library_id",
            class: "mt-2 w-full rounded-md border border-zinc-700 bg-zinc-900 px-3 py-2 text-sm text-zinc-100 focus:border-cyan-300 focus:outline-none focus:ring-2 focus:ring-cyan-300/30" %>
        </div>
        <div>
          <label for="notes" class="text-xs font-semibold uppercase tracking-wide text-zinc-500">Notes</label>
          <%= select_tag :notes,
            options_for_select([ [ "Any", "" ], [ "Has notes", "with" ], [ "No notes", "without" ] ], @filter_params[:notes]),
            id: "notes",
            class: "mt-2 w-full rounded-md border border-zinc-700 bg-zinc-900 px-3 py-2 text-sm text-zinc-100 focus:border-cyan-300 focus:outline-none focus:ring-2 focus:ring-cyan-300/30" %>
        </div>
        <div>
          <label for="streaming" class="text-xs font-semibold uppercase tracking-wide text-zinc-500">Streaming</label>
          <%= select_tag :streaming,
            options_for_select([ [ "Any", "" ], [ "Has streamed", "streamed" ], [ "Never/unknown", "never" ] ], @filter_params[:streaming]),
            id: "streaming",
            class: "mt-2 w-full rounded-md border border-zinc-700 bg-zinc-900 px-3 py-2 text-sm text-zinc-100 focus:border-cyan-300 focus:outline-none focus:ring-2 focus:ring-cyan-300/30" %>
        </div>
        <div class="flex items-end gap-2">
          <button type="submit" class="inline-flex items-center justify-center rounded-md bg-cyan-300 px-4 py-2 text-sm font-semibold text-zinc-950 transition hover:bg-cyan-200 focus:outline-none focus:ring-2 focus:ring-cyan-200 focus:ring-offset-2 focus:ring-offset-zinc-950">Filter</button>
          <%= link_to "Clear", users_path, class: "inline-flex items-center justify-center rounded-md border border-zinc-700 px-4 py-2 text-sm font-semibold text-zinc-200 transition hover:border-zinc-500 hover:bg-zinc-900 focus:outline-none focus:ring-2 focus:ring-zinc-500 focus:ring-offset-2 focus:ring-offset-zinc-950" %>
        </div>
        <%= hidden_field_tag :sort, @sort %>
        <%= hidden_field_tag :direction, @direction %>
      <% end %>
      <p class="mt-3 text-xs text-zinc-500"><%= pluralize(@users.size, "user") %> shown</p>

      <div class="mt-5 border-t border-zinc-800 pt-5">
        <%= form_with url: bulk_shares_path,
          method: :post,
          id: "bulk_access_form",
          class: "grid gap-3 lg:grid-cols-[minmax(10rem,12rem)_minmax(12rem,18rem)_auto]",
          data: {
            action: "submit->confirmation#confirmSubmit",
            confirm_bulk_summary: "true",
            confirm_title: "Apply bulk library change?",
            confirm_body: "This will update the selected users' Plex library access.",
            confirm_button: "Apply changes"
          } do %>
          <div>
            <label for="operation" class="text-xs font-semibold uppercase tracking-wide text-zinc-500">Action</label>
            <%= select_tag :operation,
              options_for_select([ [ "Add library", "add" ], [ "Remove library", "remove" ] ]),
              id: "operation",
              class: "mt-2 w-full rounded-md border border-zinc-700 bg-zinc-900 px-3 py-2 text-sm text-zinc-100 focus:border-cyan-300 focus:outline-none focus:ring-2 focus:ring-cyan-300/30" %>
          </div>
          <div>
            <label for="bulk_library_id" class="text-xs font-semibold uppercase tracking-wide text-zinc-500">Library</label>
            <%= select_tag :library_id,
              options_for_select(@libraries.map { |library| [ library.title, library.id ] }),
              id: "bulk_library_id",
              class: "mt-2 w-full rounded-md border border-zinc-700 bg-zinc-900 px-3 py-2 text-sm text-zinc-100 focus:border-cyan-300 focus:outline-none focus:ring-2 focus:ring-cyan-300/30" %>
          </div>
          <div class="flex items-end">
            <button type="submit" class="inline-flex items-center justify-center rounded-md bg-cyan-300 px-4 py-2 text-sm font-semibold text-zinc-950 transition hover:bg-cyan-200 focus:outline-none focus:ring-2 focus:ring-cyan-200 focus:ring-offset-2 focus:ring-offset-zinc-950">Apply to selected</button>
          </div>
        <% end %>
        <p class="mt-2 text-xs text-zinc-500">Select accepted users below. Pending invites and users without share IDs are skipped.</p>
      </div>

      <dialog data-confirmation-target="dialog" class="w-[calc(100%-2rem)] max-w-md rounded-lg border border-zinc-700 bg-zinc-950 p-0 text-zinc-100 shadow-2xl backdrop:bg-black/70">
        <div class="p-5">
          <h2 data-confirmation-target="title" class="text-lg font-semibold text-white">Confirm action</h2>
          <p data-confirmation-target="body" class="mt-2 text-sm leading-6 text-zinc-400">This action cannot be undone.</p>
          <div class="mt-5 flex justify-end gap-2">
            <button type="button" data-action="confirmation#cancel" class="inline-flex items-center justify-center rounded-md border border-zinc-700 px-4 py-2 text-sm font-semibold text-zinc-200 transition hover:border-zinc-500 hover:bg-zinc-900 focus:outline-none focus:ring-2 focus:ring-zinc-500 focus:ring-offset-2 focus:ring-offset-zinc-950">Cancel</button>
            <button type="button" data-confirmation-target="confirmButton" data-action="confirmation#submit" class="inline-flex items-center justify-center rounded-md bg-red-300 px-4 py-2 text-sm font-semibold text-red-950 transition hover:bg-red-100 focus:outline-none focus:ring-2 focus:ring-red-300 focus:ring-offset-2 focus:ring-offset-zinc-950">Confirm</button>
          </div>
        </div>
      </dialog>
    </section>
  <% end %>

  <% if @snapshot.present? && @users.empty? %>
    <section class="rounded-lg border border-zinc-800 bg-zinc-900 p-5">
      <p class="text-sm leading-6 text-zinc-400">No users match those filters.</p>
    </section>
  <% elsif @users.any? %>
    <section class="overflow-hidden rounded-lg border border-zinc-800 bg-zinc-950">
      <table class="min-w-full divide-y divide-zinc-800 text-left text-sm">
        <thead class="bg-zinc-900/80 text-xs uppercase tracking-wide text-zinc-400">
          <tr>
            <th class="w-12 px-4 py-3 font-semibold">Select</th>
            <th class="px-4 py-3 font-semibold"><%= users_sort_link("Name", "name") %></th>
            <th class="px-4 py-3 font-semibold">Email</th>
            <th class="px-4 py-3 font-semibold">Invitation</th>
            <th class="px-4 py-3 font-semibold"><%= users_sort_link("Last Streamed", "last_streamed") %></th>
            <th class="px-4 py-3 font-semibold">Shared Libraries</th>
            <th class="px-4 py-3 font-semibold">Notes</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-zinc-800">
          <% @users.each do |user| %>
            <% note = @notes_by_user_id[user.id.to_s] %>
            <tr>
              <td class="px-4 py-3">
                <% if user.share_id.present? && !user.pending %>
                  <%= check_box_tag "user_ids[]",
                    user.id,
                    false,
                    form: "bulk_access_form",
                    aria: { label: "Select #{user.label}" },
                    class: "size-4 rounded border-zinc-700 bg-zinc-950 text-cyan-300 focus:ring-cyan-300/30" %>
                <% end %>
              </td>
              <td class="px-4 py-3 font-medium text-white"><%= link_to user.title.presence || user.label, user_path(user.id), class: "hover:text-cyan-300" %></td>
              <td class="px-4 py-3 text-zinc-300"><%= user.email.presence || "unknown" %></td>
              <td class="px-4 py-3">
                <% if user.pending %>
                  <span class="inline-flex rounded-md border border-amber-400/30 bg-amber-400/10 px-2 py-1 text-xs font-semibold text-amber-200">Pending</span>
                <% else %>
                  <span class="inline-flex rounded-md border border-emerald-400/30 bg-emerald-400/10 px-2 py-1 text-xs font-semibold text-emerald-200">Accepted</span>
                <% end %>
              </td>
              <td class="px-4 py-3 text-zinc-300">
                <div><%= optional_plex_timestamp(user.last_streamed_at) %></div>
                <% if user.last_streamed_title.present? %>
                  <div class="mt-1 text-xs text-zinc-500"><%= user.last_streamed_title %></div>
                <% end %>
              </td>
              <td class="max-w-md px-4 py-3 text-zinc-300">
                <% if user.libraries.any? %>
                  <p class="text-sm"><%= user.libraries.map(&:title).to_sentence %></p>
                  <% if user.all_libraries %>
                    <p class="mt-1 text-xs text-cyan-300">All libraries</p>
                  <% end %>
                <% else %>
                  <p class="text-sm text-zinc-500">
                    <%= user.pending ? pluralize(user.library_count, "pending library") : "No libraries" %>
                  </p>
                <% end %>
              </td>
              <td class="min-w-80 px-4 py-3 text-zinc-300">
                <%= form_with scope: :plex_user_note, url: user_note_path(user.id), method: :patch, class: "flex items-start gap-2" do |form| %>
                  <%= hidden_field_tag :sort, @sort %>
                  <%= hidden_field_tag :direction, @direction %>
                  <% @filter_params.each do |key, value| %>
                    <%= hidden_field_tag key, value if value.present? %>
                  <% end %>
                  <%= form.hidden_field :username, value: user.username %>
                  <%= form.hidden_field :email, value: user.email %>
                  <%= form.text_area :notes,
                    value: note&.notes,
                    rows: 2,
                    placeholder: "Local admin notes",
                    class: "min-h-16 w-full rounded-md border border-zinc-700 bg-zinc-900 px-3 py-2 text-sm text-zinc-100 focus:border-cyan-300 focus:outline-none focus:ring-2 focus:ring-cyan-300/30" %>
                  <button type="submit" class="inline-flex shrink-0 items-center justify-center rounded-md bg-cyan-300 px-3 py-2 text-xs font-semibold text-zinc-950 transition hover:bg-cyan-200 focus:outline-none focus:ring-2 focus:ring-cyan-200 focus:ring-offset-2 focus:ring-offset-zinc-950">Save</button>
                <% end %>
                <% if note&.updated_at.present? %>
                  <p class="mt-1 text-xs text-zinc-500">
                    Saved <%= time_ago_in_words(note.updated_at) %> ago
                    <% if note.last_edited_by.present? %>
                      by <%= note.last_edited_by %>
                    <% end %>
                  </p>
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </section>
  <% end %>
</div>
