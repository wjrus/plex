<% content_for :title, "Plex User" %>

<div class="mx-auto flex w-full max-w-[100rem] flex-col gap-6 px-4 py-6 sm:px-6 lg:px-8">
  <header class="flex min-h-16 flex-col gap-4 border-b border-zinc-800 pb-5 sm:flex-row sm:items-center sm:justify-between">
    <div class="flex min-w-0 flex-wrap items-baseline gap-x-3 gap-y-1">
      <% if @user.present? %>
        <h1 class="text-3xl font-semibold tracking-normal text-white"><%= @user.label %></h1>
        <span class="text-sm text-zinc-400"><%= @user.email.presence || @user.username.presence || "No email or username in snapshot" %></span>
      <% else %>
        <h1 class="text-3xl font-semibold tracking-normal text-white">User unavailable</h1>
      <% end %>
    </div>
    <%= render "shared/page_nav" %>
  </header>

  <% if @configuration_error.present? || @plex_error.present? %>
    <section class="rounded-lg border border-amber-500/40 bg-amber-950/40 p-5">
      <h2 class="text-lg font-semibold text-amber-100">Unavailable</h2>
      <p class="mt-2 text-sm leading-6 text-amber-50/80"><%= @configuration_error || @plex_error %></p>
    </section>
  <% elsif @user.present? %>
    <section class="grid gap-3 sm:grid-cols-2 xl:grid-cols-4">
      <div class="rounded-lg border border-zinc-800 bg-zinc-950 p-4">
        <p class="text-xs font-medium uppercase tracking-wide text-zinc-500">Status</p>
        <p class="mt-2 text-lg font-semibold text-white"><%= suppressed_user?(@user) ? "Suppressed" : (@user.pending ? "Pending" : (local_history_user?(@user) ? "Local history" : "Active")) %></p>
      </div>
      <div class="rounded-lg border border-zinc-800 bg-zinc-950 p-4">
        <p class="text-xs font-medium uppercase tracking-wide text-zinc-500">Shared Libraries</p>
        <p class="mt-2 text-lg font-semibold text-white"><%= @user.all_libraries ? "All" : number_with_delimiter(@user.libraries.size) %></p>
      </div>
      <div class="rounded-lg border border-zinc-800 bg-zinc-950 p-4">
        <p class="text-xs font-medium uppercase tracking-wide text-zinc-500">Local Plays</p>
        <p class="mt-2 text-lg font-semibold text-white"><%= number_with_delimiter(@stream_stats[:total]) %></p>
      </div>
      <div class="rounded-lg border border-zinc-800 bg-zinc-950 p-4">
        <p class="text-xs font-medium uppercase tracking-wide text-zinc-500">Last Streamed</p>
        <p class="mt-2 text-lg font-semibold text-white"><%= @stream_stats[:last] ? l(@stream_stats[:last], format: :short) : optional_plex_timestamp(@user.last_streamed_at) %></p>
      </div>
    </section>

    <div data-controller="confirmation" class="grid gap-6 xl:grid-cols-[minmax(0,1fr)_24rem]">
      <section class="rounded-lg border border-zinc-800 bg-zinc-950 p-5">
        <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
          <div>
            <h2 class="text-lg font-semibold text-white">Library Access</h2>
            <p class="mt-1 text-sm text-zinc-400">
              <%= @user.pending ? "This invite has not been accepted yet." : "Choose exactly which libraries this user can access." %>
            </p>
          </div>
          <div class="flex flex-wrap gap-2">
            <% if suppressed_user?(@user) %>
              <span class="inline-flex rounded-md border border-zinc-500/40 bg-zinc-500/10 px-2 py-1 text-xs font-semibold text-zinc-200">Suppressed</span>
            <% end %>
            <% if @user.pending %>
              <span class="inline-flex rounded-md border border-amber-400/30 bg-amber-400/10 px-2 py-1 text-xs font-semibold text-amber-200">Pending</span>
            <% elsif local_history_user?(@user) %>
              <span class="inline-flex rounded-md border border-cyan-300/30 bg-cyan-300/10 px-2 py-1 text-xs font-semibold text-cyan-100">Local history</span>
            <% else %>
              <span class="inline-flex rounded-md border border-emerald-400/30 bg-emerald-400/10 px-2 py-1 text-xs font-semibold text-emerald-200">Active</span>
            <% end %>
            <% if @user.all_libraries %>
              <span class="inline-flex rounded-md border border-cyan-300/30 bg-cyan-300/10 px-2 py-1 text-xs font-semibold text-cyan-100">All libraries</span>
            <% end %>
          </div>
        </div>

        <% if @user.share_id.present? %>
          <%= form_with url: share_path(@user.share_id),
            method: :patch,
            class: "mt-5",
            data: {
              action: "submit->confirmation#confirmSubmit",
              confirm_library_summary: "true",
              confirm_when_empty: "true",
              confirm_title: "Remove Plex share?",
              confirm_body: "Saving with no libraries selected will revoke this user's access to this Plex server.",
              confirm_button: "Remove share"
            } do %>
            <%= hidden_field_tag :return_to, user_path(@user.id) %>
            <% selected_library_ids = @user.libraries.map { |library| library.id.to_s } %>
            <div class="grid gap-2 sm:grid-cols-2 lg:grid-cols-3">
              <% @libraries.each do |library| %>
                <% input_id = "share_#{@user.share_id}_library_#{library.id}" %>
                <label for="<%= input_id %>" class="flex min-h-12 cursor-pointer items-start gap-3 rounded-md border border-zinc-700 bg-zinc-900 px-3 py-3 text-sm text-zinc-200 transition hover:border-zinc-500">
                  <%= check_box_tag "library_ids[]",
                    library.id,
                    selected_library_ids.include?(library.id.to_s),
                    id: input_id,
                    data: { library_title: library.title },
                    class: "mt-0.5 size-4 rounded border-zinc-700 bg-zinc-950 text-cyan-300 focus:ring-cyan-300/30" %>
                  <span class="min-w-0">
                    <span class="block truncate font-semibold text-zinc-100"><%= library.title %></span>
                    <span class="block text-xs text-zinc-500"><%= library.type %></span>
                  </span>
                </label>
              <% end %>
            </div>
            <div class="mt-4 flex flex-wrap items-center gap-3">
              <button type="submit" class="inline-flex items-center justify-center rounded-md bg-cyan-300 px-4 py-2 text-sm font-semibold text-zinc-950 transition hover:bg-cyan-200 focus:outline-none focus:ring-2 focus:ring-cyan-200 focus:ring-offset-2 focus:ring-offset-zinc-950">Save libraries</button>
              <p class="text-xs text-zinc-500">Saving with no libraries checked revokes this server share.</p>
            </div>
          <% end %>
        <% elsif @user.pending %>
          <div class="mt-5 rounded-md border border-zinc-800 bg-zinc-900 p-4">
            <p class="text-sm text-zinc-300">
              Pending invite for <%= pluralize(@user.library_count, "library") %>.
              <% if @user.libraries.any? %>
                <span class="block text-zinc-500"><%= @user.libraries.map(&:title).to_sentence %></span>
              <% else %>
                <span class="block text-zinc-500">Plex does not expose the exact pending library list here.</span>
              <% end %>
            </p>
            <div class="mt-4 flex flex-wrap items-center gap-3">
              <%= button_to "Cancel invite",
                pending_invite_path(@user.id),
                method: :delete,
                form: {
                  data: {
                    action: "submit->confirmation#confirmSubmit",
                    confirm_title: "Cancel invite for #{@user.label}?",
                    confirm_body: "This will cancel the pending Plex library invite before it is accepted.",
                    confirm_button: "Cancel invite"
                  }
                },
                class: "danger-button inline-flex items-center justify-center rounded-md border px-4 py-2 text-sm font-semibold transition focus:outline-none focus:ring-2 focus:ring-red-300 focus:ring-offset-2 focus:ring-offset-zinc-950" %>
              <p class="text-xs text-zinc-500">To resend, cancel this invite and send a new one from the shares page.</p>
            </div>
          </div>
        <% elsif local_history_user?(@user) %>
          <div class="mt-5 rounded-md border border-zinc-800 bg-zinc-900 p-4">
            <p class="text-sm text-zinc-400">This account appears in local playback history but is not a shared-library user on this Plex server, so library edits are unavailable.</p>
            <div class="mt-4 flex flex-wrap items-center gap-3">
              <% if suppressed_user?(@user) %>
                <%= button_to "Unsuppress user",
                  user_suppression_path(@user.id),
                  method: :patch,
                  params: { suppressed: "0", return_to: user_path(@user.id) },
                  class: "inline-flex cursor-pointer items-center justify-center rounded-md border border-zinc-700 px-4 py-2 text-sm font-semibold text-zinc-200 transition hover:border-zinc-500 hover:bg-zinc-900 hover:text-white focus:outline-none focus:ring-2 focus:ring-zinc-500 focus:ring-offset-2 focus:ring-offset-zinc-950" %>
              <% else %>
                <%= button_to "Suppress user",
                  user_suppression_path(@user.id),
                  method: :patch,
                  params: { suppressed: "1", return_to: user_path(@user.id) },
                  form: {
                    data: {
                      action: "submit->confirmation#confirmSubmit",
                      confirm_title: "Suppress #{@user.label}?",
                      confirm_body: "This hides the local history-only account from the default Users and Access lists without deleting stream history.",
                      confirm_button: "Suppress user"
                    }
                  },
                  class: "danger-button inline-flex cursor-pointer items-center justify-center rounded-md border px-4 py-2 text-sm font-semibold transition focus:outline-none focus:ring-2 focus:ring-red-300 focus:ring-offset-2 focus:ring-offset-zinc-950" %>
              <% end %>
              <p class="text-xs text-zinc-500">Stream history remains stored and can be restored later from the suppressed filter.</p>
            </div>
          </div>
        <% else %>
          <p class="mt-5 rounded-md border border-zinc-800 bg-zinc-900 p-4 text-sm text-zinc-400">This user did not include a Plex share id in the snapshot, so library edits are unavailable.</p>
        <% end %>
      </section>

      <aside class="grid gap-6">
        <section class="rounded-lg border border-zinc-800 bg-zinc-950 p-5">
          <h2 class="text-lg font-semibold text-white">Details</h2>
          <dl class="mt-4 grid gap-2 text-sm text-zinc-400">
            <div><dt class="inline text-zinc-500">User ID:</dt> <dd class="inline"><%= @user.id %></dd></div>
            <div><dt class="inline text-zinc-500">Share ID:</dt> <dd class="inline"><%= @user.share_id.presence || "unknown" %></dd></div>
            <div><dt class="inline text-zinc-500">Invitation:</dt> <dd class="inline"><%= suppressed_user?(@user) ? "Suppressed" : (@user.pending ? "Pending" : (local_history_user?(@user) ? "Local history only" : "Accepted")) %></dd></div>
            <% if @user.pending && @user.invited_at.present? %>
              <div><dt class="inline text-zinc-500">Invited:</dt> <dd class="inline"><%= optional_plex_timestamp(@user.invited_at) %></dd></div>
            <% end %>
            <div><dt class="inline text-zinc-500">Last streamed:</dt> <dd class="inline"><%= optional_plex_timestamp(@user.last_streamed_at) %></dd></div>
            <% if @user.last_streamed_title.present? %>
              <div><dt class="inline text-zinc-500">Last title:</dt> <dd class="inline"><%= @user.last_streamed_title %></dd></div>
            <% end %>
            <div><dt class="inline text-zinc-500">Home:</dt> <dd class="inline"><%= @user.home ? "yes" : "no" %></dd></div>
            <div><dt class="inline text-zinc-500">Sync:</dt> <dd class="inline"><%= @user.allow_sync ? "allowed" : "off" %></dd></div>
          </dl>
        </section>

        <section class="rounded-lg border border-zinc-800 bg-zinc-950 p-5">
          <h2 class="text-lg font-semibold text-white">Shared Libraries</h2>
          <% if @user.libraries.any? %>
            <div class="mt-4 flex flex-wrap gap-2">
              <% @user.libraries.each do |library| %>
                <span class="inline-flex rounded-md border border-zinc-700 bg-zinc-900 px-2.5 py-1.5 text-xs font-semibold text-zinc-200"><%= library.title %></span>
              <% end %>
            </div>
          <% else %>
            <p class="mt-3 text-sm text-zinc-400"><%= @user.pending ? pluralize(@user.library_count, "pending library") : "No libraries shared." %></p>
          <% end %>
        </section>

        <section class="rounded-lg border border-zinc-800 bg-zinc-950 p-5">
          <div class="flex items-start justify-between gap-3">
            <h2 class="text-lg font-semibold text-white">Stats</h2>
            <%= link_to "CSV",
              user_path(@user.id, format: :csv),
              class: "inline-flex items-center justify-center rounded-md border border-zinc-700 px-3 py-1.5 text-xs font-semibold text-zinc-200 transition hover:border-zinc-500 hover:bg-zinc-900 focus:outline-none focus:ring-2 focus:ring-zinc-500 focus:ring-offset-2 focus:ring-offset-zinc-950" %>
          </div>
          <dl class="mt-4 grid gap-2 text-sm text-zinc-400">
            <div><dt class="inline text-zinc-500">Plays:</dt> <dd class="inline"><%= number_with_delimiter(@stream_stats[:total]) %></dd></div>
            <div><dt class="inline text-zinc-500">Last 30 days:</dt> <dd class="inline"><%= number_with_delimiter(@stream_stats[:last_30_days]) %></dd></div>
            <div><dt class="inline text-zinc-500">Last 90 days:</dt> <dd class="inline"><%= number_with_delimiter(@stream_stats[:last_90_days]) %></dd></div>
            <div><dt class="inline text-zinc-500">First seen:</dt> <dd class="inline"><%= @stream_stats[:first] ? l(@stream_stats[:first], format: :long) : "Unknown" %></dd></div>
            <div><dt class="inline text-zinc-500">Last seen:</dt> <dd class="inline"><%= @stream_stats[:last] ? l(@stream_stats[:last], format: :long) : "Unknown" %></dd></div>
            <div><dt class="inline text-zinc-500">Top type:</dt> <dd class="inline"><%= @stream_stats[:top_type] %></dd></div>
            <div><dt class="inline text-zinc-500">Top library:</dt> <dd class="inline"><%= @stream_stats[:top_library] %></dd></div>
          </dl>
        </section>

        <section class="rounded-lg border border-zinc-800 bg-zinc-950 p-5">
          <h2 class="text-lg font-semibold text-white">Notes</h2>
          <%= form_with scope: :plex_user_note, url: user_note_path(@user.id), method: :patch, class: "mt-4 grid gap-3" do |form| %>
            <%= hidden_field_tag :return_to, user_path(@user.id) %>
            <%= form.hidden_field :username, value: @user.username %>
            <%= form.hidden_field :email, value: @user.email %>
            <%= form.text_area :notes,
              value: @note&.notes,
              rows: 6,
              placeholder: "Local admin notes",
              class: "min-h-36 w-full rounded-md border border-zinc-700 bg-zinc-900 px-3 py-2 text-sm text-zinc-100 focus:border-cyan-300 focus:outline-none focus:ring-2 focus:ring-cyan-300/30" %>
            <div class="flex flex-wrap items-center gap-3">
              <button type="submit" class="inline-flex items-center justify-center rounded-md bg-cyan-300 px-4 py-2 text-sm font-semibold text-zinc-950 transition hover:bg-cyan-200 focus:outline-none focus:ring-2 focus:ring-cyan-200 focus:ring-offset-2 focus:ring-offset-zinc-950">Save notes</button>
              <% if @note&.updated_at.present? %>
                <p class="text-xs text-zinc-500">Saved <%= time_ago_in_words(@note.updated_at) %> ago</p>
              <% end %>
            </div>
          <% end %>
        </section>

        <% if @user.share_id.present? %>
          <section class="danger-panel rounded-lg border p-5">
            <h2 class="text-lg font-semibold">Remove Access</h2>
            <p class="mt-2 text-sm leading-6">Revoke this user's access to every library on this Plex server.</p>
            <%= button_to "Remove user from Plex shares",
              share_path(@user.share_id),
              method: :delete,
              form: {
                class: "mt-4",
                data: {
                  action: "submit->confirmation#confirmSubmit",
                  confirm_title: "Remove #{@user.label}?",
                  confirm_body: "This will revoke #{@user.label}'s access to all libraries on this Plex server.",
                  confirm_button: "Remove user"
                }
              },
              class: "danger-button inline-flex items-center justify-center rounded-md border px-4 py-2 text-sm font-semibold transition focus:outline-none focus:ring-2 focus:ring-red-300 focus:ring-offset-2 focus:ring-offset-zinc-950" %>
          </section>
        <% end %>
      </aside>

      <dialog data-confirmation-target="dialog" class="confirmation-dialog w-[calc(100%-2rem)] max-w-md rounded-lg border border-zinc-700 bg-zinc-950 p-0 text-zinc-100 shadow-2xl">
        <div class="p-5">
          <h2 data-confirmation-target="title" class="text-lg font-semibold text-white">Confirm action</h2>
          <p data-confirmation-target="body" class="mt-2 text-sm leading-6 text-zinc-400">This action cannot be undone.</p>
          <div class="mt-5 flex justify-end gap-2">
            <button type="button" data-action="confirmation#cancel" class="inline-flex items-center justify-center rounded-md border border-zinc-700 px-4 py-2 text-sm font-semibold text-zinc-200 transition hover:border-zinc-500 hover:bg-zinc-900 focus:outline-none focus:ring-2 focus:ring-zinc-500 focus:ring-offset-2 focus:ring-offset-zinc-950">Cancel</button>
            <button type="button" data-confirmation-target="confirmButton" data-action="confirmation#submit" class="inline-flex items-center justify-center rounded-md bg-red-300 px-4 py-2 text-sm font-semibold text-red-950 transition hover:bg-red-100 focus:outline-none focus:ring-2 focus:ring-red-300 focus:ring-offset-2 focus:ring-offset-zinc-950">Confirm</button>
          </div>
        </div>
      </dialog>
    </div>

    <section class="grid gap-4 xl:grid-cols-3">
      <div class="rounded-lg border border-zinc-800 bg-zinc-950 p-5">
        <h2 class="text-lg font-semibold text-white">Monthly Activity</h2>
        <div class="mt-4 grid gap-3">
          <% @stream_monthly_stats.each do |stat| %>
            <div class="grid grid-cols-[5.5rem_minmax(0,1fr)_3.5rem] items-center gap-3 text-sm">
              <span class="text-zinc-400"><%= stat[:label] %></span>
              <div class="h-2 overflow-hidden rounded-full bg-zinc-900">
                <div class="h-full rounded-full bg-cyan-300" style="width: <%= percentage_width(stat[:plays], @max_stream_monthly_plays) %>%"></div>
              </div>
              <span class="text-right text-zinc-300"><%= number_with_delimiter(stat[:plays]) %></span>
            </div>
          <% end %>
        </div>
      </div>

      <div class="rounded-lg border border-zinc-800 bg-zinc-950 p-5">
        <h2 class="text-lg font-semibold text-white">Type Mix</h2>
        <div class="mt-4 grid gap-3">
          <% @stream_type_stats.each do |stat| %>
            <div>
              <div class="flex items-baseline justify-between gap-3 text-sm">
                <span class="font-medium text-white"><%= stat[:label] %></span>
                <span class="text-zinc-400"><%= number_with_delimiter(stat[:plays]) %></span>
              </div>
              <div class="mt-2 h-2 overflow-hidden rounded-full bg-zinc-900">
                <div class="h-full rounded-full bg-cyan-300" style="width: <%= percentage_width(stat[:plays], @max_stream_type_plays) %>%"></div>
              </div>
            </div>
          <% end %>
          <% if @stream_type_stats.empty? %>
            <p class="text-sm text-zinc-400">No typed history yet.</p>
          <% end %>
        </div>
      </div>

      <div class="rounded-lg border border-zinc-800 bg-zinc-950 p-5">
        <h2 class="text-lg font-semibold text-white">Top Titles</h2>
        <div class="mt-4 grid gap-3">
          <% @stream_top_titles.each do |stat| %>
            <div>
              <div class="flex items-baseline justify-between gap-3 text-sm">
                <span class="min-w-0 truncate font-medium text-white"><%= stat[:label] %></span>
                <span class="shrink-0 text-zinc-400"><%= number_with_delimiter(stat[:plays]) %></span>
              </div>
              <div class="mt-2 h-2 overflow-hidden rounded-full bg-zinc-900">
                <div class="h-full rounded-full bg-cyan-300" style="width: <%= percentage_width(stat[:plays], @max_stream_title_plays) %>%"></div>
              </div>
              <p class="mt-1 text-xs text-zinc-500">Latest <%= stat[:latest] ? l(stat[:latest], format: :short) : "unknown" %></p>
            </div>
          <% end %>
          <% if @stream_top_titles.empty? %>
            <p class="text-sm text-zinc-400">No title history yet.</p>
          <% end %>
        </div>
      </div>
    </section>

    <%= render "stream_history" %>

    <section class="overflow-hidden rounded-lg border border-zinc-800 bg-zinc-950">
      <div class="border-b border-zinc-800 p-5">
        <h2 class="text-lg font-semibold text-white">Recent Log</h2>
      </div>
      <% if @audit_logs.empty? %>
        <p class="p-5 text-sm text-zinc-400">No logged changes for this user yet.</p>
      <% else %>
        <table class="min-w-full divide-y divide-zinc-800 text-left text-sm">
          <thead class="bg-zinc-900/80 text-xs uppercase tracking-wide text-zinc-400">
            <tr>
              <th class="px-4 py-3 font-semibold">When</th>
              <th class="px-4 py-3 font-semibold">Admin</th>
              <th class="px-4 py-3 font-semibold">Action</th>
              <th class="px-4 py-3 font-semibold">Details</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-zinc-800">
            <% @audit_logs.each do |entry| %>
              <tr>
                <td class="whitespace-nowrap px-4 py-3 text-zinc-300"><%= l(entry.created_at, format: :long) %></td>
                <td class="px-4 py-3 text-zinc-300"><%= entry.admin_email %></td>
                <td class="px-4 py-3 font-medium text-white"><%= entry.summary %></td>
                <td class="px-4 py-3 text-zinc-400"><%= entry.details.presence || "No additional details" %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      <% end %>
    </section>
  <% end %>
</div>
