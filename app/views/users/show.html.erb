<% content_for :title, "Plex User" %>

<div class="mx-auto flex w-full max-w-[100rem] flex-col gap-6 px-4 py-6 sm:px-6 lg:px-8">
  <header class="flex flex-col gap-4 border-b border-zinc-800 pb-5 sm:flex-row sm:items-end sm:justify-between">
    <div>
      <p class="text-sm font-medium uppercase tracking-wide text-cyan-300">Plex user</p>
      <% if @user.present? %>
        <h1 class="mt-2 text-3xl font-semibold tracking-normal text-white"><%= @user.label %></h1>
        <p class="mt-2 text-sm text-zinc-400"><%= @user.email.presence || @user.username.presence || "No email or username in snapshot" %></p>
      <% else %>
        <h1 class="mt-2 text-3xl font-semibold tracking-normal text-white">User unavailable</h1>
      <% end %>
    </div>
    <div class="flex flex-wrap gap-2">
      <%= link_to "Log", share_audit_logs_path, class: "inline-flex items-center justify-center rounded-md border border-zinc-700 px-4 py-2 text-sm font-semibold text-zinc-200 transition hover:border-zinc-500 hover:bg-zinc-900 focus:outline-none focus:ring-2 focus:ring-zinc-500 focus:ring-offset-2 focus:ring-offset-zinc-950" %>
      <%= link_to "Users", users_path, class: "inline-flex items-center justify-center rounded-md border border-zinc-700 px-4 py-2 text-sm font-semibold text-zinc-200 transition hover:border-zinc-500 hover:bg-zinc-900 focus:outline-none focus:ring-2 focus:ring-zinc-500 focus:ring-offset-2 focus:ring-offset-zinc-950" %>
      <%= link_to "Shares", root_path, class: "inline-flex items-center justify-center rounded-md border border-zinc-700 px-4 py-2 text-sm font-semibold text-zinc-200 transition hover:border-zinc-500 hover:bg-zinc-900 focus:outline-none focus:ring-2 focus:ring-zinc-500 focus:ring-offset-2 focus:ring-offset-zinc-950" %>
    </div>
  </header>

  <% if @configuration_error.present? || @plex_error.present? %>
    <section class="rounded-lg border border-amber-500/40 bg-amber-950/40 p-5">
      <h2 class="text-lg font-semibold text-amber-100">Unavailable</h2>
      <p class="mt-2 text-sm leading-6 text-amber-50/80"><%= @configuration_error || @plex_error %></p>
    </section>
  <% elsif @user.present? %>
    <section class="grid gap-4 lg:grid-cols-[minmax(0,1fr)_minmax(20rem,28rem)]">
      <div class="rounded-lg border border-zinc-800 bg-zinc-950 p-5">
        <h2 class="text-lg font-semibold text-white">Shared Libraries</h2>
        <% if @user.libraries.any? %>
          <div class="mt-4 grid gap-2 sm:grid-cols-2 xl:grid-cols-3">
            <% @user.libraries.each do |library| %>
              <div class="rounded-md border border-zinc-800 bg-zinc-900 p-3">
                <p class="font-semibold text-white"><%= library.title %></p>
                <p class="mt-1 text-xs text-zinc-500"><%= library.type %></p>
              </div>
            <% end %>
          </div>
        <% else %>
          <p class="mt-3 text-sm text-zinc-400"><%= @user.pending ? pluralize(@user.library_count, "pending library") : "No libraries currently shared." %></p>
        <% end %>
      </div>

      <div class="rounded-lg border border-zinc-800 bg-zinc-950 p-5">
        <h2 class="text-lg font-semibold text-white">Metadata</h2>
        <dl class="mt-4 grid gap-2 text-sm text-zinc-400">
          <div><dt class="inline text-zinc-500">User ID:</dt> <dd class="inline"><%= @user.id %></dd></div>
          <div><dt class="inline text-zinc-500">Share ID:</dt> <dd class="inline"><%= @user.share_id.presence || "unknown" %></dd></div>
          <div><dt class="inline text-zinc-500">Invitation:</dt> <dd class="inline"><%= @user.pending ? "Pending" : "Accepted" %></dd></div>
          <% if @user.pending && @user.invited_at.present? %>
            <div><dt class="inline text-zinc-500">Invited:</dt> <dd class="inline"><%= optional_plex_timestamp(@user.invited_at) %></dd></div>
          <% end %>
          <div><dt class="inline text-zinc-500">Last streamed:</dt> <dd class="inline"><%= optional_plex_timestamp(@user.last_streamed_at) %></dd></div>
          <% if @user.last_streamed_title.present? %>
            <div><dt class="inline text-zinc-500">Last title:</dt> <dd class="inline"><%= @user.last_streamed_title %></dd></div>
          <% end %>
          <div><dt class="inline text-zinc-500">Home:</dt> <dd class="inline"><%= @user.home ? "yes" : "no" %></dd></div>
          <div><dt class="inline text-zinc-500">Sync:</dt> <dd class="inline"><%= @user.allow_sync ? "allowed" : "off" %></dd></div>
        </dl>
      </div>
    </section>

    <section class="rounded-lg border border-zinc-800 bg-zinc-950 p-5">
      <h2 class="text-lg font-semibold text-white">Notes</h2>
      <%= form_with scope: :plex_user_note, url: user_note_path(@user.id), method: :patch, class: "mt-4 grid gap-3" do |form| %>
        <%= hidden_field_tag :return_to, user_path(@user.id) %>
        <%= form.hidden_field :username, value: @user.username %>
        <%= form.hidden_field :email, value: @user.email %>
        <%= form.text_area :notes,
          value: @note&.notes,
          rows: 5,
          placeholder: "Local admin notes",
          class: "min-h-32 w-full rounded-md border border-zinc-700 bg-zinc-900 px-3 py-2 text-sm text-zinc-100 focus:border-cyan-300 focus:outline-none focus:ring-2 focus:ring-cyan-300/30" %>
        <div class="flex items-center gap-3">
          <button type="submit" class="inline-flex items-center justify-center rounded-md bg-cyan-300 px-4 py-2 text-sm font-semibold text-zinc-950 transition hover:bg-cyan-200 focus:outline-none focus:ring-2 focus:ring-cyan-200 focus:ring-offset-2 focus:ring-offset-zinc-950">Save notes</button>
          <% if @note&.updated_at.present? %>
            <p class="text-xs text-zinc-500">Saved <%= time_ago_in_words(@note.updated_at) %> ago</p>
          <% end %>
        </div>
      <% end %>
    </section>

    <section class="overflow-hidden rounded-lg border border-zinc-800 bg-zinc-950">
      <div class="border-b border-zinc-800 p-5">
        <h2 class="text-lg font-semibold text-white">Recent Log</h2>
      </div>
      <% if @audit_logs.empty? %>
        <p class="p-5 text-sm text-zinc-400">No logged changes for this user yet.</p>
      <% else %>
        <table class="min-w-full divide-y divide-zinc-800 text-left text-sm">
          <thead class="bg-zinc-900/80 text-xs uppercase tracking-wide text-zinc-400">
            <tr>
              <th class="px-4 py-3 font-semibold">When</th>
              <th class="px-4 py-3 font-semibold">Admin</th>
              <th class="px-4 py-3 font-semibold">Action</th>
              <th class="px-4 py-3 font-semibold">Details</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-zinc-800">
            <% @audit_logs.each do |entry| %>
              <tr>
                <td class="whitespace-nowrap px-4 py-3 text-zinc-300"><%= l(entry.created_at, format: :long) %></td>
                <td class="px-4 py-3 text-zinc-300"><%= entry.admin_email %></td>
                <td class="px-4 py-3 font-medium text-white"><%= entry.summary %></td>
                <td class="px-4 py-3 text-zinc-400"><%= entry.details.presence || "No additional details" %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      <% end %>
    </section>
  <% end %>
</div>
