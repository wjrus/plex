<% content_for :title, "Plex Stats" %>

<div class="mx-auto flex w-full max-w-[100rem] flex-col gap-6 px-4 py-6 sm:px-6 lg:px-8">
  <header class="flex min-h-16 flex-col gap-4 border-b border-zinc-800 pb-5 sm:flex-row sm:items-center sm:justify-between">
    <div class="flex min-w-0 flex-wrap items-baseline gap-x-3 gap-y-1">
      <h1 class="text-3xl font-semibold tracking-normal text-white">Stats</h1>
    </div>
    <%= render "shared/page_nav" %>
  </header>

  <% if @configuration_error.present? || @plex_error.present? %>
    <section class="rounded-lg border border-amber-500/40 bg-amber-950/40 p-5">
      <h2 class="text-lg font-semibold text-amber-100">Unavailable</h2>
      <p class="mt-2 text-sm leading-6 text-amber-50/80"><%= @configuration_error || @plex_error %></p>
    </section>
  <% else %>
    <nav class="flex flex-wrap gap-2" aria-label="Stats period">
      <% @stats_period_options.each do |period, label| %>
        <% active = period == @stats_period %>
        <%= link_to label,
          stats_path(period: period),
          class: [
            "inline-flex cursor-pointer items-center justify-center rounded-md border px-4 py-2 text-sm font-semibold transition focus:outline-none focus:ring-2 focus:ring-cyan-200 focus:ring-offset-2 focus:ring-offset-zinc-950",
            active ? "border-cyan-300 bg-cyan-300 text-zinc-950" : "border-zinc-700 text-zinc-200 hover:border-zinc-500 hover:bg-zinc-900 hover:text-white"
          ].join(" "),
          aria: { current: active ? "page" : nil } %>
      <% end %>
    </nav>

    <section class="grid gap-3 sm:grid-cols-3">
      <div class="rounded-lg border border-zinc-800 bg-zinc-950 p-4">
        <p class="text-xs font-medium uppercase tracking-wide text-zinc-500">Completed Plays</p>
        <p class="mt-2 text-lg font-semibold text-white"><%= number_with_delimiter(@period_summary[:completed_plays]) %></p>
        <p class="mt-1 text-xs text-zinc-500"><%= @stats_period_label %></p>
      </div>
      <div class="rounded-lg border border-zinc-800 bg-zinc-950 p-4">
        <p class="text-xs font-medium uppercase tracking-wide text-zinc-500">Oldest</p>
        <p class="mt-2 text-lg font-semibold text-white"><%= @period_summary[:oldest] ? l(@period_summary[:oldest], format: :short) : "None" %></p>
      </div>
      <div class="rounded-lg border border-zinc-800 bg-zinc-950 p-4">
        <p class="text-xs font-medium uppercase tracking-wide text-zinc-500">Newest</p>
        <p class="mt-2 text-lg font-semibold text-white"><%= @period_summary[:newest] ? l(@period_summary[:newest], format: :short) : "None" %></p>
      </div>
    </section>

    <section class="grid gap-4 xl:grid-cols-2">
      <div class="rounded-lg border border-zinc-800 bg-zinc-950 p-5">
        <h2 class="text-lg font-semibold text-white">Library Activity</h2>
        <div class="mt-4 grid gap-3">
          <% @library_stats.each do |stat| %>
            <%= link_to library_path(stat[:label]), class: "block rounded-md p-2 transition hover:bg-zinc-900" do %>
              <div class="grid min-w-0 grid-cols-[minmax(0,1fr)_auto] items-baseline gap-3 text-sm">
                <span class="min-w-0 truncate font-medium text-white" title="<%= stat[:label] %>"><%= stat[:label] %></span>
                <span class="shrink-0 text-zinc-400"><%= number_with_delimiter(stat[:plays]) %> plays · <%= pluralize(stat[:users], "user") %></span>
              </div>
              <div class="mt-2 h-2 overflow-hidden rounded-full bg-zinc-900">
                <div class="h-full rounded-full bg-cyan-300" style="width: <%= percentage_width(stat[:plays], @max_library_plays) %>%"></div>
              </div>
              <p class="mt-1 text-xs text-zinc-500">Latest <%= stat[:latest] ? l(stat[:latest], format: :short) : "unknown" %></p>
            <% end %>
          <% end %>
          <% if @library_stats.empty? %>
            <p class="text-sm text-zinc-400">No library history yet.</p>
          <% end %>
        </div>
      </div>

      <div class="rounded-lg border border-zinc-800 bg-zinc-950 p-5">
        <h2 class="text-lg font-semibold text-white">Top Users</h2>
        <div class="mt-4 grid gap-3">
          <% @top_users.each do |stat| %>
            <%= link_to user_path(stat[:account_id]), class: "block rounded-md border border-zinc-800 bg-zinc-900 p-3 transition hover:border-zinc-500 hover:bg-zinc-900/80" do %>
              <div class="grid min-w-0 grid-cols-[minmax(0,1fr)_auto] items-baseline gap-3 text-sm">
                <span class="min-w-0 truncate font-medium text-white" title="<%= stat[:label] %>"><%= stat[:label] %></span>
                <span class="shrink-0 text-zinc-400"><%= number_with_delimiter(stat[:plays]) %> plays</span>
              </div>
              <div class="mt-2 h-2 overflow-hidden rounded-full bg-zinc-950">
                <div class="h-full rounded-full bg-cyan-300" style="width: <%= percentage_width(stat[:plays], @max_user_plays) %>%"></div>
              </div>
              <p class="mt-1 text-xs text-zinc-500">Latest <%= stat[:latest] ? l(stat[:latest], format: :short) : "unknown" %></p>
            <% end %>
          <% end %>
          <% if @top_users.empty? %>
            <p class="text-sm text-zinc-400">No user history yet.</p>
          <% end %>
        </div>
      </div>

      <div class="rounded-lg border border-zinc-800 bg-zinc-950 p-5">
        <h2 class="text-lg font-semibold text-white">Media Types</h2>
        <div class="mt-4 grid gap-3">
          <% @type_stats.each do |stat| %>
            <div>
              <div class="grid min-w-0 grid-cols-[minmax(0,1fr)_auto] items-baseline gap-3 text-sm">
                <span class="min-w-0 truncate font-medium text-white" title="<%= stat[:label] %>"><%= stat[:label] %></span>
                <span class="shrink-0 text-zinc-400"><%= number_with_delimiter(stat[:plays]) %> plays · <%= pluralize(stat[:users], "user") %></span>
              </div>
              <div class="mt-2 h-2 overflow-hidden rounded-full bg-zinc-900">
                <div class="h-full rounded-full bg-cyan-300" style="width: <%= percentage_width(stat[:plays], @max_type_plays) %>%"></div>
              </div>
            </div>
          <% end %>
          <% if @type_stats.empty? %>
            <p class="text-sm text-zinc-400">No media type history yet.</p>
          <% end %>
        </div>
      </div>

      <div class="rounded-lg border border-zinc-800 bg-zinc-950 p-5">
        <h2 class="text-lg font-semibold text-white">Activity</h2>
        <div class="mt-4 grid gap-3">
          <% @activity_stats.each do |stat| %>
            <div class="grid grid-cols-[5.5rem_minmax(0,1fr)_4rem] items-center gap-3 text-sm">
              <span class="text-zinc-400"><%= stat[:label] %></span>
              <div class="h-2 overflow-hidden rounded-full bg-zinc-900">
                <div class="h-full rounded-full bg-cyan-300" style="width: <%= percentage_width(stat[:plays], @max_activity_plays) %>%"></div>
              </div>
              <span class="text-right text-zinc-300"><%= number_with_delimiter(stat[:plays]) %></span>
            </div>
          <% end %>
          <% if @activity_stats.empty? %>
            <p class="text-sm text-zinc-400">No activity in this period.</p>
          <% end %>
        </div>
      </div>
    </section>
  <% end %>
</div>
