PLEX_TOKEN=
PLEX_MACHINE_IDENTIFIER=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
ADMIN_USERS=admin@example.com

# Optional. Defaults are usually fine.
PLEX_API_BASE_URL=https://plex.tv
# Optional but needed for "last streamed"; use the URL where this app can reach
# your Plex Media Server, for example http://127.0.0.1:32400.
PLEX_SERVER_BASE_URL=
PLEX_HISTORY_PAGE_SIZE=1000
PLEX_HISTORY_MAX_PAGES=all
# The rake refresh task defaults this to 730 days (about 24 months) when unset.
PLEX_HISTORY_DAYS=730
PLEX_HISTORY_RETRIES=8
PLEX_CLIENT_IDENTIFIER=plex-shares-local
PLEX_CLIENT_NAME=Plex Shares
PLEX_NOW_PLAYING_SAMPLE_INTERVAL=60
PLEX_NOW_PLAYING_RETENTION_DAYS=90
PLEX_DAILY_REFRESH_AT=04:15
PLEX_DAILY_REFRESH_DAYS=1

# Optional. Labels a local playback-history account, useful for showing the
# server owner's own stats even though owners are not shared-library users.
PLEX_OWNER_ACCOUNT_ID=
PLEX_OWNER_NAME=
PLEX_OWNER_USERNAME=
PLEX_OWNER_EMAIL=
