#!/usr/bin/env bash
set -Eeuo pipefail

interval="${PLEX_NOW_PLAYING_SAMPLE_INTERVAL:-60}"
last_prune_date=""

while true; do
  echo "Sampling Plex now playing sessions"
  if ./bin/rails plex:sample_now_playing; then
    echo "Now playing sample completed"
  else
    echo "Now playing sample failed" >&2
  fi

  today="$(date -u +%F)"
  if [[ "$today" != "$last_prune_date" ]]; then
    echo "Pruning old now playing samples"
    if ./bin/rails plex:prune_now_playing_samples; then
      last_prune_date="$today"
    else
      echo "Now playing sample prune failed" >&2
    fi
  fi

  sleep "$interval"
done
